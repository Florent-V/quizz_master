{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe{% endblock %}

{% block body %}
<div class="flex items-center justify-center min-h-screen">
    <div class="w-full max-w-md p-6 rounded-lg shadow-lg bg-base-100">
        <h1 class="text-2xl font-bold text-center mb-5">Définir un nouveau mot de passe</h1>
        {{ form_start(resetForm) }}
        {% for error in form_errors(resetForm) %}
            <div class="alert alert-error mb-4 flex items-center">
                <svg class="w-5 h-5 mr-2 text-red-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                <span>{{ error.message }}</span>
            </div>
        {% endfor %}
            {{ include('_include/_password_fields.html.twig', {form: resetForm}) }}
            {# Afficher les champs cachés restants (CSRF, token) mais pas les champs visibles non voulus #}
            {{ form_rest(resetForm, {render_rest: false}) }}
            <button class="btn btn-primary w-full">Réinitialiser le mot de passe</button>
        {{ form_end(resetForm) }}
    </div>
</div>
{% endblock %}
