{% extends 'base.html.twig' %}

{% block title %}Hello HomeController!{% endblock %}

{% block body %}

    <div class="container flex flex-col flex-grow items-center justify-center">

        <div class="flex flex-col md:flex-row flex-grow items-center justify-center bg-base-100 p-6">
            <!-- Logo Section -->
            <div class="flex justify-center mb-6 md:mb-0 md:mr-8">
                <img alt="Symfony Logo" class="logo w-60 h-60" src="./images/symfony_dynamic_02.svg">
            </div>

            <!-- Content Section -->
            <div class="flex flex-col items-center md:items-start text-center md:text-left">
                <div class="greetings">
                    <h1 class="text-4xl font-bold text-primary mb-2">You did it!</h1>
                    <h3 class="text-lg text-base-content mb-4">
                        You’ve successfully created a project with
                        <a href="https://symfony.com/" target="_blank" rel="noopener" class="link link-primary">Symfony</a> and
                        <a href="https://ux.symfony.com/" target="_blank" rel="noopener" class="link link-primary">Symfony UX</a> styling with
                        <br>
                        <a href="https://tailwindcss.com/" target="_blank" rel="noopener" class="link link-primary">Tailwind CSS</a>/
                        <a href="https://daisyui.com/" target="_blank" rel="noopener" class="link link-primary">DaisyUI</a> using the
                        <a href="https://github.com/Florent-V/omega" target="_blank" rel="noopener" class="link link-primary">Symfony Omega Starter</a> template! What's next?
                    </h3>
                </div>
                <nav class="space-x-4">
                    <a href="/" class="btn btn-ghost">Home</a>
                    <a href="/about" class="btn btn-ghost">About</a>
                    <a href="/theme" class="btn btn-primary">Theme Preview</a>
                </nav>
            </div>
        </div>

    </div>
{% endblock %}
