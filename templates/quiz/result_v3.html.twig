{% extends 'base.html.twig' %}

{% block title %}Résultats du Quiz - {{ quizSession.pseudo }}{% endblock %}

{% block body %}
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <div class="navbar bg-primary text-primary-content shadow-lg">
        <div class="flex-1">
            <h1 class="text-xl font-bold">
                <i class="fas fa-trophy mr-2"></i>
                Résultats du Quiz
            </h1>
        </div>
        <div class="flex-none">
            <div class="dropdown dropdown-end">
                <div tabindex="0" role="button" class="btn btn-ghost">
                    <i class="fas fa-ellipsis-v"></i>
                </div>
                <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow bg-base-100 rounded-box w-52">
                    <li><a href="{{ path('app_quiz_configure') }}"><i class="fas fa-redo mr-2"></i>Nouveau quiz</a></li>
                    <li><a onclick="window.print()"><i class="fas fa-print mr-2"></i>Imprimer</a></li>
                    <li><a onclick="shareResults()"><i class="fas fa-share mr-2"></i>Partager</a></li>
                </ul>
            </div>
        </div>
    </div>
    <div class="container mx-auto px-4 py-8">
        <div class="max-w-6xl mx-auto">

            <!-- Résumé principal -->
            <div class="text-center mb-8 animate-fade-in-up">
                {% set successRate = totalQuestions > 0 ? (correctAnswers / totalQuestions * 100) : 0 %}

                <!-- Badge de performance -->
                <div class="mb-6">
                    {% if successRate == 100 %}
                        <div class="badge badge-success badge-lg text-lg p-4">
                            <i class="fas fa-crown mr-2"></i>
                            PARFAIT !
                        </div>
                    {% elseif successRate >= 80 %}
                        <div class="badge badge-info badge-lg text-lg p-4">
                            <i class="fas fa-star mr-2"></i>
                            EXCELLENT
                        </div>
                    {% elseif successRate >= 60 %}
                        <div class="badge badge-warning badge-lg text-lg p-4">
                            <i class="fas fa-thumbs-up mr-2"></i>
                            BIEN
                        </div>
                    {% else %}
                        <div class="badge badge-error badge-lg text-lg p-4">
                            <i class="fas fa-redo mr-2"></i>
                            RÉESSAYEZ
                        </div>
                    {% endif %}
                </div>

                <h1 class="text-4xl font-bold mb-2">{{ quizSession.pseudo }}</h1>
                <p class="text-xl text-base-content/70">
                    Mode: {{ quizSession.gameMode.value|title }} •
                    {% if quizSession.status == 'finished' and correctAnswers < totalQuestions %}
                        Quiz terminé sur une mauvaise réponse
                    {% else %}
                        Quiz complété avec succès
                    {% endif %}
                </p>
            </div>

            <!-- Statistiques principales -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                <!-- Score -->
                <div class="stat bg-gradient-to-br from-success/20 to-success/5 rounded-2xl border border-success/20 animate-fade-in-up"
                     style="animation-delay: 0.1s">
                    <div class="stat-figure text-success">
                        <i class="fas fa-trophy text-3xl"></i>
                    </div>
                    <div class="stat-title text-success-content">Score</div>
                    <div class="stat-value text-success">{{ quizSession.score }}</div>
                    <div class="stat-desc">{{ correctAnswers }}/{{ totalQuestions }} correctes</div>
                </div>

                <!-- Temps total -->
                <div class="stat bg-gradient-to-br from-info/20 to-info/5 rounded-2xl border border-info/20 animate-fade-in-up"
                     style="animation-delay: 0.2s">
                    <div class="stat-figure text-info">
                        <i class="fas fa-clock text-3xl"></i>
                    </div>
                    <div class="stat-title text-info-content">Temps total</div>
                    <div class="stat-value text-info">
                        {% set minutes = (totalTime / 60)|round(0, 'floor') %}
                        {% set seconds = totalTime % 60 %}
                        {{ minutes }}:{{ seconds < 10 ? '0' ~ seconds : seconds }}
                    </div>
                    <div class="stat-desc">{{ totalTime }} secondes</div>
                </div>

                <!-- Temps moyen -->
                <div class="stat bg-gradient-to-br from-warning/20 to-warning/5 rounded-2xl border border-warning/20 animate-fade-in-up"
                     style="animation-delay: 0.3s">
                    <div class="stat-figure text-warning">
                        <i class="fas fa-stopwatch text-3xl"></i>
                    </div>
                    <div class="stat-title text-warning-content">Temps moyen</div>
                    <div class="stat-value text-warning">{{ averageTime }}s</div>
                    <div class="stat-desc">par question</div>
                </div>

                <!-- Pourcentage -->
                <div class="stat bg-gradient-to-br from-primary/20 to-primary/5 rounded-2xl border border-primary/20 animate-fade-in-up"
                     style="animation-delay: 0.4s">
                    <div class="stat-figure text-primary">
                        <i class="fas fa-percent text-3xl"></i>
                    </div>
                    <div class="stat-title text-primary-content">Réussite</div>
                    <div class="stat-value text-primary">{{ successRate|round }}%</div>
                    <div class="stat-desc">{{ correctAnswers }} bonnes réponses</div>
                </div>
            </div>

            <!-- Graphiques de performance -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
                <!-- Graphique en barres des temps de réponse -->
                <div class="card bg-base-100 shadow-xl border border-base-300 animate-fade-in-up"
                     style="animation-delay: 0.5s">
                    <div class="card-body">
                        <h3 class="card-title mb-4">
                            <i class="fas fa-chart-bar mr-2"></i>
                            Temps de réponse par question
                        </h3>
                        <canvas id="timeChart" width="400" height="200"></canvas>
                    </div>
                </div>

                <!-- Graphique en secteurs -->
                <div class="card bg-base-100 shadow-xl border border-base-300 animate-fade-in-up"
                     style="animation-delay: 0.6s">
                    <div class="card-body">
                        <h3 class="card-title mb-4">
                            <i class="fas fa-chart-pie mr-2"></i>
                            Répartition des réponses
                        </h3>
                        <canvas id="resultsChart" width="400" height="200"></canvas>
                    </div>
                </div>
            </div>

            <!-- Détail des questions -->
            <div class="card bg-base-100 shadow-xl border border-base-300 mb-8 animate-fade-in-up"
                 style="animation-delay: 0.7s">
                <div class="card-body">
                    <h3 class="card-title mb-6">
                        <i class="fas fa-list mr-2"></i>
                        Détail des réponses
                    </h3>

                    <div class="space-y-4">
                        {% for answer in answers %}
                            <div class="collapse collapse-arrow border border-base-300
                                {% if answer.isCorrect %}border-success/50 bg-success/5{% else %}border-error/50 bg-error/5{% endif %}">
                                <input type="radio" name="question-accordion" />
                                <div class="collapse-title">
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center gap-4">
                                            <div class="badge {% if answer.isCorrect %}badge-success{% else %}badge-error{% endif %}">
                                                <i class="fas {% if answer.isCorrect %}fa-check{% else %}fa-times{% endif %} mr-1"></i>
                                                Q{{ loop.index }}
                                            </div>
                                            <span class="font-medium">{{ answer.question.content|length > 80 ? answer.question.content|slice(0, 80) ~ '...' : answer.question.content }}</span>
                                        </div>
                                        <div class="flex items-center gap-2">
                                            <span class="badge badge-outline">{{ answer.time }}s</span>
                                            <span class="badge badge-ghost">{{ answer.question.difficulty.name }}</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="collapse-content">
                                    <div class="pt-4">
                                        <!-- Question complète -->
                                        <div class="mb-4">
                                            <h4 class="font-semibold mb-2">Question :</h4>
                                            <div class="flex gap-4">
                                                {% if answer.question.imageName %}
                                                    <div class="avatar">
                                                        <div class="w-20 h-20 rounded-lg border-2 border-base-300">
                                                            <img src="{{ vich_uploader_asset(answer.question, 'imageFile') }}"
                                                                 alt="Question" class="object-cover">
                                                        </div>
                                                    </div>
                                                {% endif %}
                                                <p class="text-base-content">{{ answer.question.content }}</p>
                                            </div>
                                        </div>

                                        <!-- Réponses -->
                                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                                            {% for proposal in answer.question.proposals %}
                                                <div class="p-4 rounded-lg border-2
                                                {% if proposal.isCorrect %}border-success bg-success/10{% elseif answer.proposal and answer.proposal.id == proposal.id and not proposal.isCorrect %}border-error bg-error/10{% else %}border-base-300 bg-base-50{% endif %}">
                                                    <div class="flex items-center gap-3">
                                                        {% if proposal.imageName %}
                                                            <div class="avatar">
                                                                <div class="w-12 h-12 rounded border border-base-300">
                                                                    <img src="{{ vich_uploader_asset(proposal, 'imageFile') }}"
                                                                         alt="Proposition" class="object-cover">
                                                                </div>
                                                            </div>
                                                        {% endif %}
                                                        <div class="flex-1">
                                                            <p class="font-medium">{{ proposal.content }}</p>
                                                        </div>
                                                        <div class="flex-none">
                                                            {% if proposal.isCorrect %}
                                                                <i class="fas fa-check-circle text-success text-xl"></i>
                                                            {% elseif answer.proposal and answer.proposal.id == proposal.id and not proposal.isCorrect %}
                                                                <i class="fas fa-times-circle text-error text-xl"></i>
                                                            {% endif %}
                                                        </div>
                                                    </div>
                                                </div>
                                            {% endfor %}
                                        </div>

                                        <!-- Explication si disponible -->
                                        {% if answer.question.explanation %}
                                            <div class="alert alert-info">
                                                <i class="fas fa-info-circle"></i>
                                                <div>
                                                    <h4 class="font-bold">Explication :</h4>
                                                    <p>{{ answer.question.explanation }}</p>
                                                </div>
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="text-center space-x-4 animate-fade-in-up" style="animation-delay: 0.8s">
                <a href="{{ path('app_quiz_configure') }}" class="btn btn-primary btn-lg">
                    <i class="fas fa-redo mr-2"></i>
                    Nouveau Quiz
                </a>
                <button onclick="window.print()" class="btn btn-outline btn-lg no-print">
                    <i class="fas fa-print mr-2"></i>
                    Imprimer
                </button>
                <button onclick="shareResults()" class="btn btn-ghost btn-lg no-print">
                    <i class="fas fa-share mr-2"></i>
                    Partager
                </button>
            </div>

            <!-- Modal de partage -->
            <dialog id="share_modal" class="modal">
                <div class="modal-box">
                    <h3 class="font-bold text-lg mb-4">Partager vos résultats</h3>
                    <div class="space-y-4">
                        <div class="text-center p-6 bg-base-200 rounded-lg">
                            <div class="text-2xl font-bold">{{ quizSession.pseudo }}</div>
                            <div class="text-lg">Score: {{ quizSession.score }}/{{ totalQuestions }}</div>
                            <div class="text-base text-base-content/70">{{ successRate|round }}% de réussite</div>
                        </div>
                        <div class="form-control">
                            <label class="label">Texte à copier :</label>
                            <textarea id="shareText" class="textarea textarea-bordered h-24" readonly>🧠 Quiz terminé !
{{ quizSession.pseudo }} a obtenu {{ quizSession.score }}/{{ totalQuestions }} ({{ successRate|round }}%)
Temps total: {{ (totalTime / 60)|round(0, 'floor') }}:{{ (totalTime % 60) < 10 ? '0' ~ (totalTime % 60) : (totalTime % 60) }}
Mode: {{ quizSession.gameMode.value|title }}</textarea>
                        </div>
                        <div class="flex justify-center gap-2">
                            <button class="btn btn-primary" onclick="copyToClipboard()">
                                <i class="fas fa-copy mr-2"></i>
                                Copier
                            </button>
                        </div>
                    </div>
                    <div class="modal-action">
                        <form method="dialog">
                            <button class="btn">Fermer</button>
                        </form>
                    </div>
                </div>
            </dialog>
        </div>
    </div>

    <script>
      // Fonction pour partager les résultats
      function shareResults() {
        document.getElementById('share_modal').showModal();
      }

      // Fonction pour copier le texte
      async function copyToClipboard() {
        const text = document.getElementById('shareText').value;
        try {
          await navigator.clipboard.writeText(text);
          showNotification('Texte copié dans le presse-papier !', 'success');
        } catch (err) {
          console.error('Erreur lors de la copie:', err);
          // Fallback pour les navigateurs plus anciens
          const textarea = document.getElementById('shareText');
          textarea.select();
          textarea.setSelectionRange(0, 99999); // Pour les mobiles
          document.execCommand('copy');
          showNotification('Texte copié dans le presse-papier !', 'success');
        }
      }

      // Fonction pour afficher les notifications (optionnelle)
      function showNotification(message, type) {
        // Vous pouvez implémenter votre système de notification ici
        // Par exemple avec une toast notification
        console.log(`${type}: ${message}`);

        // Exemple simple avec une alerte temporaire
        const alertDiv = document.createElement('div');
        alertDiv.className = `alert alert-${type} fixed top-4 right-4 z-50 w-auto`;
        alertDiv.innerHTML = `
                <i class="fas fa-check-circle"></i>
                <span>${message}</span>
            `;
        document.body.appendChild(alertDiv);

        setTimeout(() => {
          alertDiv.remove();
        }, 3000);
      }

      // Initialisation des graphiques au chargement de la page
      document.addEventListener('DOMContentLoaded', function() {
        initCharts();
      });

      function initCharts() {
        // Graphique des temps de réponse
        const timeCtx = document.getElementById('timeChart').getContext('2d');
        console.log("timeCtx", timeCtx)
        const timeData = {
          labels: [
              {% for answer in answers %}
            'Q{{ loop.index }}'{% if not loop.last %},{% endif %}
              {% endfor %}
          ],
          datasets: [{
            label: 'Temps (secondes)',
            data: [
                {% for answer in answers %}
                {{ answer.time }}{% if not loop.last %},{% endif %}
                {% endfor %}
            ],
            backgroundColor: [
                {% for answer in answers %}
              '{% if answer.isCorrect %}rgba(34, 197, 94, 0.8){% else %}rgba(239, 68, 68, 0.8){% endif %}'{% if not loop.last %},{% endif %}
                {% endfor %}
            ],
            borderColor: [
                {% for answer in answers %}
              '{% if answer.isCorrect %}rgb(34, 197, 94){% else %}rgb(239, 68, 68){% endif %}'{% if not loop.last %},{% endif %}
                {% endfor %}
            ],
            borderWidth: 2,
            borderRadius: 8,
            borderSkipped: false,
          }]
        };
        console.log("timeData", timeData)

        const test = new Chart(timeCtx, {
          type: 'bar',
          data: timeData,
          options: {
            responsive: true,
            plugins: {
              legend: {
                display: false
              },
              tooltip: {
                backgroundColor: 'rgba(0, 0, 0, 0.8)',
                titleColor: '#fff',
                bodyColor: '#fff',
                borderColor: 'rgba(255, 255, 255, 0.2)',
                borderWidth: 1,
                cornerRadius: 8,
              }
            },
            scales: {
              y: {
                beginAtZero: true,
                title: {
                  display: true,
                  text: 'Temps (secondes)',
                  font: {
                    weight: 'bold'
                  }
                },
                grid: {
                  color: 'rgba(0, 0, 0, 0.1)'
                }
              },
              x: {
                title: {
                  display: true,
                  text: 'Questions',
                  font: {
                    weight: 'bold'
                  }
                },
                grid: {
                  display: false
                }
              }
            },
            animation: {
              duration: 2000,
              easing: 'easeOutBounce'
            }
          }
        });
        console.log("chart", test)

        // Graphique en secteurs
        const resultsCtx = document.getElementById('resultsChart').getContext('2d');
        new Chart(resultsCtx, {
          type: 'doughnut',
          data: {
            labels: ['Correctes', 'Incorrectes'],
            datasets: [{
              data: [{{ correctAnswers }}, {{ totalQuestions - correctAnswers }}],
              backgroundColor: [
                'rgba(34, 197, 94, 0.8)',
                'rgba(239, 68, 68, 0.8)'
              ],
              borderColor: [
                'rgb(34, 197, 94)',
                'rgb(239, 68, 68)'
              ],
              borderWidth: 3,
              hoverOffset: 4
            }]
          },
          options: {
            responsive: true,
            plugins: {
              legend: {
                position: 'bottom',
                labels: {
                  padding: 20,
                  font: {
                    size: 14,
                    weight: 'bold'
                  }
                }
              },
              tooltip: {
                backgroundColor: 'rgba(0, 0, 0, 0.8)',
                titleColor: '#fff',
                bodyColor: '#fff',
                borderColor: 'rgba(255, 255, 255, 0.2)',
                borderWidth: 1,
                cornerRadius: 8,
                callbacks: {
                  label: function(context) {
                    const label = context.label || '';
                    const value = context.parsed;
                    const total = context.dataset.data.reduce((a, b) => a + b, 0);
                    const percentage = Math.round((value / total) * 100);
                    return `${label}: ${value} (${percentage}%)`;
                  }
                }
              }
            },
            animation: {
              animateRotate: true,
              duration: 2000,
              easing: 'easeOutBounce'
            }
          }
        });
      }
    </script>
{% endblock %}
