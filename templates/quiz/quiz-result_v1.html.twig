{% extends 'base.html.twig' %}

{% block title %}Résultats - Quiz{% endblock %}

{% block body %}
    {% set answersData = [] %}
    {% for answer in statistics.answers %}
        {% set answersData = answersData|merge([{
            time: answer.time,
            isCorrect: answer.isCorrect,
        }]) %}
    {% endfor %}

    <div class="min-h-screen bg-base-200 py-8 px-4 sm:px-6 lg:px-8"
         data-controller="quiz-result-v1"
         data-quiz-result-v1-answers-value="{{ answersData|json_encode|e('html_attr') }}"
         data-quiz-result-v1-accuracy-value="{{ statistics.accuracy }}">
        <div class="max-w-6xl mx-auto">

            <!-- Header avec résultat principal -->
            <div class="text-center mb-12">
                <div class="hero bg-base-100 rounded-3xl shadow-2xl p-8 mb-8">
                    <div class="hero-content flex justify-center text-center">
                        <div class="w-max mx-auto">
                            {% if statistics.accuracy > 90 %}
                                <div class="text-6xl mb-4">🎉</div>
                                <h1 class="text-4xl font-bold text-success mb-2">Félicitations !</h1>
                                <p class="text-xl text-base-content/70 mb-4">Vous avez terminé le quiz avec brio !</p>
                            {% else %}
                                <div class="text-6xl mb-4">🤔</div>
                                <h1 class="text-4xl font-bold text-warning mb-2">Pas mal !</h1>
                                <p class="text-xl text-base-content/70 mb-4">Continue à t'entraîner pour progresser</p>
                            {% endif %}

                            <div class="stats stats-vertical lg:stats-horizontal shadow bg-gradient-to-r from-primary to-secondary text-white justify-center">
                                <div class="stat">
                                    <div class="stat-figure text-white">
                                        <i class="fas fa-user text-2xl opacity-80"></i>
                                    </div>
                                    <div class="stat-title text-base-content">Joueur</div>
                                    <div class="stat-value text-xl">{{ quizSession.pseudo }}</div>
                                </div>

                                <div class="stat">
                                    <div class="stat-figure text-white">
                                        <i class="fas fa-trophy text-2xl opacity-80"></i>
                                    </div>
                                    <div class="stat-title text-base-content">Score Final</div>
                                    <div class="stat-value text-xl">{{ statistics.correctAnswers }} / {{ statistics.totalQuestions }}</div>
                                </div>

                                <div class="stat">
                                    <div class="stat-figure text-white">
                                        <i class="fas fa-percentage text-2xl opacity-80"></i>
                                    </div>
                                    <div class="stat-title text-base-content">Précision</div>
                                    <div class="stat-value text-xl">{{ statistics.accuracy }}</div>
                                </div>

                                <div class="stat">
                                    <div class="stat-figure text-white">
                                        <i class="fas fa-clock text-2xl opacity-80"></i>
                                    </div>
                                    <div class="stat-title text-base-content">Temps moyen</div>
                                    <div class="stat-value text-xl">{{ statistics.averageTime }} s</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Graphique et statistiques détaillées -->
            <div class="grid lg:grid-cols-2 gap-8 mb-12">
                <!-- Graphique de performance -->
                <div class="card bg-base-100 shadow-xl">
                    <div class="card-body">
                        <h2 class="card-title text-2xl mb-4">
                            <i class="fas fa-chart-line text-primary"></i>
                            Performance par question
                        </h2>
                        <div class="h-64">
                            <canvas data-quiz-result-v1-target="performanceChart"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Statistiques détaillées -->
                <div class="card bg-base-100 shadow-xl">
                    <div class="card-body">
                        <h2 class="card-title text-2xl mb-4">
                            <i class="fas fa-chart-pie text-primary"></i>
                            Répartition des temps
                        </h2>
                        <div class="h-64">
                            <canvas data-quiz-result-v1-target="timeChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Historique des réponses -->
            <div class="card bg-base-100 shadow-xl mb-8">
                <div class="card-body">
                    <h2 class="card-title text-2xl mb-6">
                        <i class="fas fa-history text-primary"></i>
                        Historique détaillé de vos réponses
                    </h2>

                    <div class="space-y-4 max-h-96 overflow-y-auto">
                        {% for answer in statistics.answers %}
                            <div class="card card-bordered {{ answer.isCorrect ? 'border-success bg-success/10' : 'border-error bg-error/10' }}">
                                <div class="card-body p-4">
                                    <div class="flex items-start justify-between">
                                        <div class="flex-1">
                                            <div class="flex items-center mb-2">
                                                <span class="badge badge-neutral mr-2">Question {{ loop.index }}</span>
                                                {% if answer.isCorrect %}
                                                    <i class="fas fa-check-circle text-success text-lg"></i>
                                                    <span class="text-success font-semibold ml-2">Correct</span>
                                                {% else %}
                                                    <i class="fas fa-times-circle text-error text-lg"></i>
                                                    <span class="text-error font-semibold ml-2">Incorrect</span>
                                                {% endif %}
                                            </div>

                                            <h3 class="font-semibold text-base-content mb-2">{{ answer.question.content }}</h3>

                                            <div class="space-y-1">
                                                <p class="text-sm">
                                                    <span class="font-medium">Votre réponse:</span>
                                                    {% if answer.proposal %}
                                                        <span class="{{ answer.isCorrect ? 'text-success' : 'text-error' }}">
                                                        {{ answer.proposal.content }}
                                                    </span>
                                                    {% else %}
                                                        <span class="text-base-content/50 italic">Aucune réponse</span>
                                                    {% endif %}
                                                </p>

                                                {% if not answer.isCorrect %}
                                                    {% for proposal in answer.question.proposals %}
                                                        {% if proposal.isCorrect %}
                                                            <p class="text-sm">
                                                                <span class="font-medium">Bonne réponse:</span>
                                                                <span class="text-success">{{ proposal.content }}</span>
                                                            </p>
                                                        {% endif %}
                                                    {% endfor %}
                                                {% endif %}

                                                {% if answer.question.explanation %}
                                                    <div class="mt-3 p-3 bg-info/10 rounded-lg border-l-4 border-info">
                                                        <p class="text-sm text-info">
                                                            <i class="fas fa-info-circle mr-1"></i>
                                                            <strong>Explication:</strong> {{ answer.question.explanation }}
                                                        </p>
                                                    </div>
                                                {% endif %}
                                            </div>
                                        </div>

                                        <div class="text-right ml-4">
                                            <div class="badge badge-ghost">
                                                <twig:ux:icon name="fa7-solid:clock" class="w-4 h-4" />
                                                {{ answer.time }}s
                                            </div>
                                            <div class="badge badge-ghost">
                                                <twig:ux:icon name="mdi:tag" class="w-4 h-4" />
                                                {{ answer.question.category.name }}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="text-center space-y-4">
                <div class="space-x-4">
                    <a href="{{ path('app_quiz_restart') }}"
                       class="btn btn-primary btn-lg bg-gradient-to-r from-primary to-secondary border-none hover:from-primary-focus hover:to-secondary-focus text-white font-bold shadow-lg hover:shadow-xl transform hover:scale-105 transition-all duration-200">
                        <i class="fas fa-redo mr-2"></i>
                        Recommencer un quiz
                    </a>

                    <button data-action="click->quiz-result-v1#printResults"
                            class="btn btn-outline btn-lg border-primary text-primary hover:bg-primary hover:text-white">
                        <i class="fas fa-print mr-2"></i>
                        Imprimer les résultats
                    </button>
                </div>

                <div class="mt-6">
                    <div class="alert alert-success shadow-lg max-w-2xl mx-auto">
                        <div>
                            <i class="fas fa-lightbulb"></i>
                            <div>
                                <h3 class="font-bold">Conseil pour progresser</h3>
                                {% if statistics.accuracy < 70 %}
                                    <p class="text-sm">Prenez le temps de bien lire les questions et n'hésitez pas à utiliser les indices disponibles.</p>
                                {% elseif statistics.accuracy < 90 %}
                                    <p class="text-sm">Très bon travail ! Continuez à vous entraîner pour atteindre l'excellence.</p>
                                {% else %}
                                    <p class="text-sm">Performances exceptionnelles ! Vous maîtrisez parfaitement le sujet.</p>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        @media print {
            .btn, .card-actions {
                display: none !important;
            }

            .card {
                box-shadow: none !important;
                border: 1px solid #e5e7eb !important;
            }
        }
    </style>
{% endblock %}
