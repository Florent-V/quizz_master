{% extends 'base.html.twig' %}

{% block title %}Résultats - Quiz{% endblock %}

{% block stylesheets %}
    <link href="https://cdn.jsdelivr.net/npm/daisyui@4.12.10/dist/full.min.css" rel="stylesheet" type="text/css" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
{% endblock %}

{% block body %}
    <div class="min-h-screen bg-gradient-to-br from-emerald-50 to-teal-100 py-8 px-4 sm:px-6 lg:px-8">
        <div class="max-w-6xl mx-auto">

            <!-- Header avec résultat principal -->
            <div class="text-center mb-12">
                <div class="hero bg-white rounded-3xl shadow-2xl p-8 mb-8">
                    <div class="hero-content text-center">
                        <div class="max-w-md">
                            {% if quizSession.status == 'finished' %}
                                <div class="text-6xl mb-4">🎉</div>
                                <h1 class="text-4xl font-bold text-emerald-600 mb-2">Félicitations !</h1>
                                <p class="text-xl text-gray-600 mb-4">Vous avez terminé le quiz avec brio !</p>
                            {% else %}
                                <div class="text-6xl mb-4">🤔</div>
                                <h1 class="text-4xl font-bold text-orange-600 mb-2">Pas mal !</h1>
                                <p class="text-xl text-gray-600 mb-4">Une petite erreur, mais c'est comme ça qu'on apprend !</p>
                            {% endif %}

                            <div class="stats stats-vertical lg:stats-horizontal shadow bg-gradient-to-r from-emerald-500 to-teal-500 text-white">
                                <div class="stat">
                                    <div class="stat-figure text-white">
                                        <i class="fas fa-user text-2xl opacity-80"></i>
                                    </div>
                                    <div class="stat-title text-emerald-100">Joueur</div>
                                    <div class="stat-value text-xl">{{ quizSession.pseudo }}</div>
                                </div>

                                <div class="stat">
                                    <div class="stat-figure text-white">
                                        <i class="fas fa-trophy text-2xl opacity-80"></i>
                                    </div>
                                    <div class="stat-title text-emerald-100">Score Final</div>
                                    <div class="stat-value">{{ statistics.correctAnswers }}</div>
                                    <div class="stat-desc text-emerald-100">sur {{ statistics.totalQuestions }} questions</div>
                                </div>

                                <div class="stat">
                                    <div class="stat-figure text-white">
                                        <i class="fas fa-percentage text-2xl opacity-80"></i>
                                    </div>
                                    <div class="stat-title text-emerald-100">Précision</div>
                                    <div class="stat-value">{{ statistics.accuracy }}%</div>
                                </div>

                                <div class="stat">
                                    <div class="stat-figure text-white">
                                        <i class="fas fa-clock text-2xl opacity-80"></i>
                                    </div>
                                    <div class="stat-title text-emerald-100">Temps moyen</div>
                                    <div class="stat-value text-xl">{{ statistics.averageTime }}s</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Graphique et statistiques détaillées -->
            <div class="grid lg:grid-cols-2 gap-8 mb-12">
                <!-- Graphique de performance -->
                <div class="card bg-white shadow-xl">
                    <div class="card-body">
                        <h2 class="card-title text-2xl mb-4">
                            <i class="fas fa-chart-line text-emerald-500"></i>
                            Performance par question
                        </h2>
                        <div class="h-64">
                            <canvas id="performanceChart"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Statistiques détaillées -->
                <div class="card bg-white shadow-xl">
                    <div class="card-body">
                        <h2 class="card-title text-2xl mb-4">
                            <i class="fas fa-chart-pie text-emerald-500"></i>
                            Répartition des temps
                        </h2>
                        <div class="h-64">
                            <canvas id="timeChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Historique des réponses -->
            <div class="card bg-white shadow-xl mb-8">
                <div class="card-body">
                    <h2 class="card-title text-2xl mb-6">
                        <i class="fas fa-history text-emerald-500"></i>
                        Historique détaillé de vos réponses
                    </h2>

                    <div class="space-y-4 max-h-96 overflow-y-auto">
                        {% for answer in statistics.answers %}
                            <div class="card card-bordered {{ answer.isCorrect ? 'border-emerald-300 bg-emerald-50' : 'border-red-300 bg-red-50' }}">
                                <div class="card-body p-4">
                                    <div class="flex items-start justify-between">
                                        <div class="flex-1">
                                            <div class="flex items-center mb-2">
                                                <span class="badge badge-neutral mr-2">Question {{ loop.index }}</span>
                                                {% if answer.isCorrect %}
                                                    <i class="fas fa-check-circle text-emerald-500 text-lg"></i>
                                                    <span class="text-emerald-700 font-semibold ml-2">Correct</span>
                                                {% else %}
                                                    <i class="fas fa-times-circle text-red-500 text-lg"></i>
                                                    <span class="text-red-700 font-semibold ml-2">Incorrect</span>
                                                {% endif %}
                                            </div>

                                            <h3 class="font-semibold text-gray-800 mb-2">{{ answer.question.content }}</h3>

                                            <div class="space-y-1">
                                                <p class="text-sm">
                                                    <span class="font-medium">Votre réponse:</span>
                                                    {% if answer.proposal %}
                                                        <span class="{{ answer.isCorrect ? 'text-emerald-600' : 'text-red-600' }}">
                                                        {{ answer.proposal.content }}
                                                    </span>
                                                    {% else %}
                                                        <span class="text-gray-500 italic">Aucune réponse</span>
                                                    {% endif %}
                                                </p>

                                                {% if not answer.isCorrect %}
                                                    {% for proposal in answer.question.proposals %}
                                                        {% if proposal.isCorrect %}
                                                            <p class="text-sm">
                                                                <span class="font-medium">Bonne réponse:</span>
                                                                <span class="text-emerald-600">{{ proposal.content }}</span>
                                                            </p>
                                                        {% endif %}
                                                    {% endfor %}
                                                {% endif %}

                                                {% if answer.question.explanation %}
                                                    <div class="mt-3 p-3 bg-blue-50 rounded-lg border-l-4 border-blue-400">
                                                        <p class="text-sm text-blue-800">
                                                            <i class="fas fa-info-circle mr-1"></i>
                                                            <strong>Explication:</strong> {{ answer.question.explanation }}
                                                        </p>
                                                    </div>
                                                {% endif %}
                                            </div>
                                        </div>

                                        <div class="text-right ml-4">
                                            <div class="badge badge-ghost">
                                                <i class="fas fa-clock mr-1"></i>
                                                {{ answer.time }}s
                                            </div>
                                            <div class="badge badge-ghost mt-1">
                                                <i class="fas fa-tag mr-1"></i>
                                                {{ answer.question.category.name }}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="text-center space-y-4">
                <div class="space-x-4">
                    <a href="{{ path('app_quiz_restart') }}"
                       class="btn btn-primary btn-lg bg-gradient-to-r from-emerald-500 to-teal-500 border-none hover:from-emerald-600 hover:to-teal-600 text-white font-bold shadow-lg hover:shadow-xl transform hover:scale-105 transition-all duration-200">
                        <i class="fas fa-redo mr-2"></i>
                        Recommencer un quiz
                    </a>

                    <button onclick="window.print()"
                            class="btn btn-outline btn-lg border-emerald-500 text-emerald-600 hover:bg-emerald-500 hover:text-white">
                        <i class="fas fa-print mr-2"></i>
                        Imprimer les résultats
                    </button>
                </div>

                <div class="mt-6">
                    <div class="alert alert-success shadow-lg max-w-2xl mx-auto">
                        <div>
                            <i class="fas fa-lightbulb"></i>
                            <div>
                                <h3 class="font-bold">Conseil pour progresser</h3>
                                {% if statistics.accuracy < 70 %}
                                    <p class="text-sm">Prenez le temps de bien lire les questions et n'hésitez pas à utiliser les indices disponibles.</p>
                                {% elseif statistics.accuracy < 90 %}
                                    <p class="text-sm">Très bon travail ! Continuez à vous entraîner pour atteindre l'excellence.</p>
                                {% else %}
                                    <p class="text-sm">Performances exceptionnelles ! Vous maîtrisez parfaitement le sujet.</p>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', function() {
        // Animation d'entrée
        const cards = document.querySelectorAll('.card');
        cards.forEach((card, index) => {
          card.style.opacity = '0';
          card.style.transform = 'translateY(30px)';
          setTimeout(() => {
            card.style.transition = 'all 0.6s ease-out';
            card.style.opacity = '1';
            card.style.transform = 'translateY(0)';
          }, 100 * index);
        });

        // Données pour les graphiques
        const answers = {{ statistics.answers|json_encode|raw }};

        // Graphique de performance
        const performanceCtx = document.getElementById('performanceChart').getContext('2d');
        const performanceChart = new Chart(performanceCtx, {
          type: 'line',
          data: {
            labels: answers.map((_, index) => `Q${index + 1}`),
            datasets: [{
              label: 'Temps de réponse (secondes)',
              data: answers.map(answer => answer.time),
              borderColor: 'rgb(16, 185, 129)',
              backgroundColor: 'rgba(16, 185, 129, 0.1)',
              borderWidth: 3,
              fill: true,
              tension: 0.4,
              pointBackgroundColor: answers.map(answer => answer.isCorrect ? '#10b981' : '#ef4444'),
              pointBorderColor: answers.map(answer => answer.isCorrect ? '#059669' : '#dc2626'),
              pointRadius: 6,
              pointHoverRadius: 8,
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
              y: {
                beginAtZero: true,
                title: {
                  display: true,
                  text: 'Temps (secondes)'
                }
              },
              x: {
                title: {
                  display: true,
                  text: 'Questions'
                }
              }
            },
            plugins: {
              legend: {
                display: true,
                position: 'top'
              },
              tooltip: {
                callbacks: {
                  afterLabel: function(context) {
                    const answer = answers[context.dataIndex];
                    return answer.isCorrect ? 'Réponse correcte' : 'Réponse incorrecte';
                  }
                }
              }
            }
          }
        });

        // Graphique de répartition des temps
        const timeCtx = document.getElementById('timeChart').getContext('2d');
        const timeRanges = ['0-5s', '6-10s', '11-20s', '20s+'];
        const timeCounts = [0, 0, 0, 0];

        answers.forEach(answer => {
          if (answer.time <= 5) timeCounts[0]++;
          else if (answer.time <= 10) timeCounts[1]++;
          else if (answer.time <= 20) timeCounts[2]++;
          else timeCounts[3]++;
        });

        const timeChart = new Chart(timeCtx, {
          type: 'doughnut',
          data: {
            labels: timeRanges,
            datasets: [{
              data: timeCounts,
              backgroundColor: [
                '#10b981',
                '#3b82f6',
                '#f59e0b',
                '#ef4444'
              ],
              borderWidth: 2,
              borderColor: '#ffffff'
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: {
                position: 'bottom'
              }
            }
          }
        });
      });

      // Effet confetti pour les bons scores
      {% if statistics.accuracy >= 80 %}
      function createConfetti() {
        const colors = ['#10b981', '#3b82f6', '#f59e0b', '#ef4444', '#8b5cf6'];
        for (let i = 0; i < 50; i++) {
          const confetti = document.createElement('div');
          confetti.style.position = 'fixed';
          confetti.style.width = '10px';
          confetti.style.height = '10px';
          confetti.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
          confetti.style.left = Math.random() * 100 + 'vw';
          confetti.style.top = '-10px';
          confetti.style.zIndex = '9999';
          confetti.style.borderRadius = '50%';

          document.body.appendChild(confetti);

          const animation = confetti.animate([
            { transform: 'translateY(0) rotate(0deg)', opacity: 1 },
            { transform: `translateY(${window.innerHeight + 20}px) rotate(360deg)`, opacity: 0 }
          ], {
            duration: Math.random() * 3000 + 2000,
            easing: 'cubic-bezier(0.25, 0.46, 0.45, 0.94)'
          });

          animation.addEventListener('finish', () => {
            confetti.remove();
          });
        }
      }

      setTimeout(createConfetti, 500);
      {% endif %}
    </script>

    <style>
        @media print {
            .btn, .card-actions {
                display: none !important;
            }

            .card {
                box-shadow: none !important;
                border: 1px solid #e5e7eb !important;
            }
        }
    </style>
{% endblock %}
