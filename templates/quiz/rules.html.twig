{% extends 'base.html.twig' %}

{% block title %}Quiz Master - Règles{% endblock %}

{% block body %}
    {# Use a container to constrain width and center content #}
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

        {# Page Title #}
        <div class="text-center mb-12">
            <h1 class="text-5xl font-bold">
                <span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">
                    Règles du Jeu
                </span>
            </h1>
            <p class="mt-4 max-w-2xl mx-auto text-lg text-base-content/80">
                Découvrez le fonctionnement de chaque mode de jeu pour devenir un vrai Quiz Master.
            </p>
        </div>

        {# The rules block itself #}
        <div class="p-6 sm:p-8 bg-base-100 rounded-2xl shadow-xl border border-base-300">
            <ul class="space-y-6">
                {% for mode in gameModes %}
                    <li>
                        <h3 class="text-2xl font-bold text-accent mb-2">{{ mode.getLabel() }}</h3>
                        <p class="text-lg text-base-content/90">{{ mode.getRule() }}</p>
                    </li>
                {% endfor %}
            </ul>
        </div>

    </div> {# End of container #}
{% endblock %}
