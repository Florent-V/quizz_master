{% extends 'base.html.twig' %}

{% block title %}Quiz en cours{% endblock %}

{% block body %}
<div class="flex-grow flex">
    <div class="bg-gradient-to-br from-base-200 to-base-300 p-4 flex-grow flex items-center justify-center">
        <div {{ vue_component('TimeAttackGame', {
            quizSessionId: quizSessionId,
        }) }} class="flex-grow"
        >
            {# Fallback content while Vue est en cours de chargement #}
            <div class="text-center">
                <span class="loading loading-spinner loading-lg"></span>
                <p>Chargement du quiz...</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
