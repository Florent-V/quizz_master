{% extends 'base.html.twig' %}

{% block title %}Edit Product{% endblock %}

{% block body %}
<div class="container mx-auto p-6">
    <h1 class="text-3xl font-bold mb-6 text-primary">{{ product.id ? 'Edit Product' : 'Create New Product' }}</h1>
    <div class="flex justify-end gap-4">
        {{ include('product/_delete_form.html.twig') }}
        <a href="{{ path('app_product_index') }}" class="btn btn-secondary btn-outline">
            ⬅ Back to list
        </a>
    </div>
    {{ include('product/_form.html.twig', {button_label: 'Update'}) }}
</div>
{% endblock %}
