{% extends 'base.html.twig' %}

{% block title %}Product index{% endblock %}

{% block body %}
<div class="container mx-auto p-6">
    <h1 class="text-3xl font-bold text-center mb-6">Liste des Produits</h1>
    <a href="{{ path('app_product_new') }}" class="btn btn-primary mb-4">Ajouter un Produit</a>
    <div class="overflow-x-auto">
        <table class="table table-zebra w-full">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Description</th>
                <th>Price</th>
                <th>Picture</th>
                <th>Stock</th>
                <th>CreatedAt</th>
                <th>UpdatedAt</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for product in products %}
            <tr>
                <td>{{ product.id }}</td>
                <td>{{ product.name }}</td>
                <td>{{ product.description }}</td>
                <td>{{ product.price }}</td>
                <td>{{ product.picture }}</td>
                <td>{{ product.stock }}</td>
                <td>{{ product.createdAt ? product.createdAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ product.updatedAt ? product.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
                <td class="flex gap-4">
                    <a href="{{ path('app_product_show', {id: product.id}) }}">
                        <twig:ux:icon name="mdi:show" class="w-6 h-6" />
                    </a>
                    <a href="{{ path('app_product_edit', {id: product.id}) }}">
                        <twig:ux:icon name="mdi:edit" class="w-6 h-6" />
                    </a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
        </table>
    </div>
</div>

{% endblock %}
