{% extends 'base.html.twig' %}

{% block title %}Product{% endblock %}

{% block body %}
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-10 max-w-screen-lg">
        <h1 class="text-3xl font-bold mb-8 text-primary text-center">Détails du produit</h1>

        <div class="bg-base-100 rounded-2xl shadow-xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="table table-zebra w-full">
                    <tbody class="text-sm sm:text-base">
                    <tr>
                        <th class="bg-base-200 p-4 text-left w-1/3">ID</th>
                        <td class="p-4">{{ product.id }}</td>
                    </tr>
                    <tr>
                        <th class="bg-base-200 p-4 text-left">Nom</th>
                        <td class="p-4">{{ product.name }}</td>
                    </tr>
                    <tr>
                        <th class="bg-base-200 p-4 text-left">Description</th>
                        <td class="p-4">{{ product.description }}</td>
                    </tr>
                    <tr>
                        <th class="bg-base-200 p-4 text-left">Prix</th>
                        <td class="p-4">{{ product.price }} €</td>
                    </tr>
                    <tr>
                        <th class="bg-base-200 p-4 text-left">Image</th>
                        <td class="p-4">
                            <img src="{{ product.picture ? vich_uploader_asset(product, 'pictureFile') : asset('build/images/default_product_image.webp') }}"
                                 alt="Image produit"
                                 class="h-32 rounded-lg shadow-md object-cover">
                        </td>
                    </tr>
                    <tr>
                        <th class="bg-base-200 p-4 text-left">Stock</th>
                        <td class="p-4">{{ product.stock }}</td>
                    </tr>
                    <tr>
                        <th class="bg-base-200 p-4 text-left">Mis à jour le</th>
                        <td class="p-4">
                            {{ product.updatedAt ? product.updatedAt|date('Y-m-d H:i:s') : 'N/A' }}
                        </td>
                    </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center sm:justify-start">
            <a href="{{ path('app_product_index') }}" class="btn btn-outline btn-secondary w-full sm:w-auto">Retour à la liste</a>
            <a href="{{ path('app_product_edit', {id: product.id}) }}" class="btn btn-primary w-full sm:w-auto">Modifier</a>
            <div class="w-full sm:w-auto">
                {{ include('product/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
