{% extends 'base.html.twig' %}

{% block title %}Historique de {{ product.name }}{% endblock %}

{% block body %}
    <div class="container mx-auto p-6">
        <h1 class="text-3xl font-bold mb-4">Historique de {{ product.name }}</h1>
        <a href="{{ path('product_history_index') }}" class="btn btn-primary mb-4">Retour</a>

        <div class="overflow-x-auto">
            <table class="table w-full">
                <thead>
                <tr class="bg-base-300">
                    <th>Date</th>
                    <th>Utilisateur</th>
                    <th>Changements</th>
                </tr>
                </thead>
                <tbody>
                {% for log in logs %}
                    <tr class="hover">
                        <td>{{ log.loggedAt|date('d/m/Y H:i') }}</td>
                        <td>{{ log.username ?: 'Système' }}</td>
                        <td>
                            <ul>
                                <li>
                                    <strong>{{ log.loggedAt|date('Y-m-d H:i:s') }}</strong>
                                    <ul>
                                        {% for field, change in log.data %}
                                            <li><strong>{{ field }}</strong>: {{ change.old }} → {{ change.new }}</li>
                                        {% endfor %}
                                    </ul>
                                </li>
                            </ul>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3" class="text-center">Aucune modification trouvée.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
