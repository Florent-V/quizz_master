<nav class="bg-base-100 shadow-md">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            <!-- Logo et Titre -->
            <div class="flex-shrink-0">
                <a href="{{ path('app_home') }}" class="flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.546-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span class="ml-3 text-xl font-bold text-base-content">Quiz Master</span>
                </a>
            </div>

            <!-- Liens de Navigation (Desktop) -->
            <div class="hidden lg:flex items-center space-x-4">
                <a href="{{ path('app_home') }}" class="text-base-content hover:text-primary px-3 py-2 rounded-md font-medium">Accueil</a>
                <a href="{{ path('app_quiz_configure') }}" class="text-base-content hover:text-primary px-3 py-2 rounded-md font-medium">Jouer</a>
                <a href="{{ path('app_quiz_rules') }}" class="text-base-content hover:text-primary px-3 py-2 rounded-md font-medium">Règles</a>
                <a href="#" class="text-base-content hover:text-primary px-3 py-2 rounded-md font-medium">Leaderboard</a>
            </div>

            <!-- Boutons & Hamburger -->
            <div class="flex items-center">
                <!-- Theme Toggle -->
                <div class="hidden lg:flex mr-4">
                    <div {{ vue_component('ThemeToggle') }}></div>
                </div>

                <!-- Boutons de connexion (Desktop) -->
                <div class="hidden lg:flex items-center">
                    {% if app.user %}
                        <div class="dropdown dropdown-end">
                            <label tabindex="0" class="btn btn-ghost btn-circle avatar">
                                <div class="w-10 rounded-full">
                                    <img src="{{ app.user.picture ? vich_uploader_asset(app.user, 'pictureFile') : asset('build/images/default-profile-picture.png') }}" alt="Avatar">
                                </div>
                            </label>
                            <ul tabindex="0" class="mt-3 z-[1] p-2 shadow menu menu-sm dropdown-content bg-base-100 rounded-box w-52">
                                <li><a href="{{ path('app_user_account') }}" class="justify-between">Profil</a></li>
                                <li><a href="{{ path('app_change_password') }}">Changer le mot de passe</a></li>
                                {% if is_granted('ROLE_ADMIN') %}
                                    <div class="divider my-1"></div>
                                    <li><a href="{{ path('admin') }}">Tableau de bord Admin</a></li>
                                {% endif %}
                                <div class="divider my-1"></div>
                                <li><a href="{{ path('app_logout') }}">Déconnexion</a></li>
                            </ul>
                        </div>
                    {% else %}
                        <div class="flex items-center space-x-2">
                            <a href="{{ path('app_login') }}" class="btn btn-ghost">Se connecter</a>
                            <a href="{{ path('app_register') }}" class="btn btn-primary">S'inscrire</a>
                        </div>
                    {% endif %}
                </div>

                <!-- Hamburger Menu (Mobile) -->
                <div class="lg:hidden flex items-center">
                    <div {{ vue_component('ThemeToggle') }}></div>
                    <div class="dropdown dropdown-end">
                        <label tabindex="0" class="btn btn-ghost">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" /></svg>
                        </label>
                        <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52">
                            <li><a href="{{ path('app_home') }}">Accueil</a></li>
                            <li><a href="#">Règles</a></li>
                            <li><a href="#">Leaderboard</a></li>
                            <div class="divider my-1"></div>
                            {% if app.user %}
                                <li><a href="{{ path('app_user_account') }}">Profil</a></li>
                                <li><a href="{{ path('app_change_password') }}">Changer le mot de passe</a></li>
                                {% if is_granted('ROLE_ADMIN') %}
                                    <li><a href="{{ path('admin') }}">Tableau de bord Admin</a></li>
                                {% endif %}
                                <div class="divider my-1"></div>
                                <li><a href="{{ path('app_logout') }}">Déconnexion</a></li>
                            {% else %}
                                <li><a href="{{ path('app_login') }}">Se connecter</a></li>
                                <li><a href="{{ path('app_register') }}">S'inscrire</a></li>
                            {% endif %}
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</nav>
