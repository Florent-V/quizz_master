<div class="mb-4">
    {{ form_label(form.plainPassword.first, null, {label_attr: {class: 'block font-medium'}}) }}
    {{ form_widget(form.plainPassword.first, {attr: {class: 'input input-bordered w-full'}}) }}
    {% for error in form.plainPassword.first.vars.errors %}
        <div class="mt-1 flex items-center text-red-600 text-sm">
            <svg class="w-4 h-4 mr-1 flex-shrink-0" viewBox="0 0 20 20" fill="red" xmlns="http://www.w3.org/2000/svg">
                <circle cx="10" cy="10" r="10" fill="red"/>
                <path d="M6 6l8 8M14 6l-8 8" stroke="white" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <span>{{ error.message }}</span>
        </div>
    {% endfor %}
</div>
