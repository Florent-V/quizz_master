{# templates/pagination/sortable.html.twig #}
{% if direction is same as('desc') %}
    <a href="{{ path(route, query|merge({(sortFieldParameterName): field, (sortDirectionParameterName): 'asc'})) }}"
       class="link link-hover flex items-center gap-1">
        {{ title }}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
        </svg>
    </a>
{% elseif direction is same as('asc') %}
    <a href="{{ path(route, query|merge({(sortFieldParameterName): field, (sortDirectionParameterName): 'desc'})) }}"
       class="link link-hover flex items-center gap-1">
        {{ title }}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
    </a>
{% else %}
    <a href="{{ path(route, query|merge({(sortFieldParameterName): field, (sortDirectionParameterName): 'asc'})) }}"
       class="link link-hover flex items-center gap-1">
        {{ title }}
    </a>
{% endif %}
