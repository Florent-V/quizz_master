{% extends 'base.html.twig' %}

{% block title %}Mon profil{% endblock %}

{% block body %}
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="bg-base-100 shadow-2xl rounded-2xl p-8 sm:p-10 max-w-screen-lg mx-auto">
            <h2 class="text-3xl font-bold mb-6 text-center">Mon profil</h2>

            <div class="flex flex-col lg:flex-row items-center lg:items-start gap-8">
                {% if user.picture %}
                    <img src="{{ vich_uploader_asset(user, 'pictureFile') }}"
                         alt="Photo de profil"
                         class="w-36 h-36 sm:w-40 sm:h-40 rounded-full object-cover shadow-md">
                {% else %}
                    <img src="{{ asset('build/images/default-profile-picture.png') }}"
                         alt="Photo de profil"
                         class="w-36 h-36 sm:w-40 sm:h-40 rounded-full object-cover shadow-md">
                {% endif %}

                <div class="w-full space-y-4 text-base-content text-sm sm:text-base">
                    <p><span class="font-semibold">Nom d'utilisateur :</span> {{ user.userName }}</p>
                    <p><span class="font-semibold">Email :</span> {{ user.email }}</p>
                    <p><span class="font-semibold">Prénom :</span> {{ user.firstName ?: 'Non renseigné' }}</p>
                    <p><span class="font-semibold">Nom :</span> {{ user.lastName ?: 'Non renseigné' }}</p>
                    <p><span class="font-semibold">Téléphone :</span> {{ user.phone ?: 'Non renseigné' }}</p>

                    <div class="mt-6 flex flex-col sm:flex-row gap-4">
                        <a href="{{ path('app_user_edit') }}" class="btn btn-primary w-full sm:w-auto">
                            Modifier
                        </a>

                        {{ include('user/_delete_form.html.twig') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
