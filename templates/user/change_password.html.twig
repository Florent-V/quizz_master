{% extends 'base.html.twig' %}

{% block title %}Changer le mot de passe{% endblock %}

{% block body %}
<div class="flex items-center justify-center min-h-screen">
    <div class="w-full max-w-md p-6 rounded-lg shadow-lg bg-base-100">
        <h1 class="text-2xl font-bold text-center mb-5">Changer le mot de passe</h1>

        {{ form_start(form) }}

        {% for error in form_errors(form) %}
            <div class="alert alert-error mb-4 flex items-center">
                <svg class="w-5 h-5 mr-2 text-red-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                <span>{{ error.message }}</span>
            </div>
        {% endfor %}

        <div class="mb-4">
            {{ form_label(form.currentPassword, null, {label_attr: {class: 'block font-medium'}}) }}
            {{ form_widget(form.currentPassword, {attr: {class: 'input input-bordered w-full'}}) }}
            {% for error in form.currentPassword.vars.errors %}
                <div class="mt-1 flex items-center text-red-600 text-sm">
                    <svg class="w-4 h-4 mr-1 flex-shrink-0" viewBox="0 0 20 20" fill="red" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="10" cy="10" r="10" fill="red"/>
                        <path d="M6 6l8 8M14 6l-8 8" stroke="white" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                    <span>{{ error.message }}</span>
                </div>
            {% endfor %}
        </div>

        {{ include('_include/_password_fields.html.twig', {form: form}) }}
        {{ form_rest(form, {render_rest: false}) }}
        <button class="btn btn-primary w-full">Changer le mot de passe</button>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
