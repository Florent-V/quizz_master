{% extends '@EasyAdmin/page/content.html.twig' %}

{% block title %}Problèmes de Performance{% endblock %}
{% block page_title %}⚠️ Détection des Problèmes de Performance{% endblock %}

{% block page_content %}
    <!-- Alert de statut général -->
    <div class="alert alert-warning">
        <i class="fas fa-exclamation-triangle"></i>
        <strong>Scan en cours:</strong> {{ issues.problematicSessions|length }} sessions problématiques détectées,
        {{ issues.slowQuestions|length }} questions avec temps de réponse lents,
        {{ issues.timeoutAnalysis.totalTimeouts }} timeouts identifiés.
    </div>

    <div class="row mb-4">
        <!-- Métriques de Problèmes -->
        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                Sessions Problématiques
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {{ issues.problematicSessions|length }}
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-exclamation-triangle fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card border-left-danger shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">
                                Questions Lentes
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {{ issues.slowQuestions|length }}
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-turtle fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                Catégories Déséquilibrées
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {{ issues.unbalancedCategories|length }}
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-balance-scale fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card border-left-secondary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-secondary text-uppercase mb-1">
                                Timeouts
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {{ issues.timeoutAnalysis.totalTimeouts }}
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-clock fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sessions Problématiques -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-warning">🚨 Sessions Problématiques</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="problematicSessionsTable">
                    <thead>
                    <tr>
                        <th>Session ID</th>
                        <th>Joueur</th>
                        <th>Score</th>
                        <th>Durée</th>
                        <th>Mode</th>
                        <th>Problème Identifié</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for session in issues.problematicSessions %}
                        <tr>
                            <td>{{ session.id }}</td>
                            <td>
                                <strong>{{ session.pseudo }}</strong>
                                {% if session.user %}
                                    <br><small class="text-muted">{{ session.user.email }}</small>
                                {% endif %}
                            </td>
                            <td>
                                {% if session.score < 10 %}
                                    <span class="badge bg-danger">{{ session.score }}</span>
                                {% else %}
                                    <span class="badge bg-warning">{{ session.score }}</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if session.finishedAt and session.startedAt %}
                                    {% set duration = session.finishedAt.timestamp - session.startedAt.timestamp %}
                                    {% if duration > 3600 %}
                                        <span class="text-danger">{{ (duration / 60)|number_format(0) }}min</span>
                                    {% else %}
                                        {{ (duration / 60)|number_format(0) }}min
                                    {% endif %}
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td>
                                {% set modes = {'20Q': '20Q', TIME_ATTACK: 'Temps', SPEED_RUN: 'Speed', SUDDEN_DEATH: 'Mort'} %}
                                {{ modes[session.gameMode.value] ?? session.gameMode.value }}
                            </td>
                            <td>
                                {% if session.score < 10 %}
                                    <span class="badge bg-danger">Score très bas</span>
                                {% endif %}
                                {% if session.finishedAt and session.startedAt and (session.finishedAt.timestamp - session.startedAt.timestamp) > 3600 %}
                                    <span class="badge bg-warning">Durée excessive</span>
                                {% endif %}
                            </td>
                            <td>
                                <a href="{{ ea_url().setController('App\\Controller\\Admin\\QuizSessionCrudController').setAction('detail').setEntityId(session.id) }}"
                                   class="btn btn-sm btn-primary"
                                >
                                    <i class="fas fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Questions avec Temps de Réponse Lents -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-danger">🐌 Questions avec Temps de Réponse Lents</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered">
                    <thead>
                    <tr>
                        <th>Question</th>
                        <th>Catégorie</th>
                        <th>Temps Moyen</th>
                        <th>Difficulté Estimée</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for question in issues.slowQuestions %}
                        <tr>
                            <td>
                                <div class="question-preview">
                                    {{ question.content|length > 100 ? question.content|slice(0, 100) ~ '...' : question.content }}
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-secondary">{{ question.category.name }}</span>
                            </td>
                            <td>
                                <span class="badge bg-danger fs-6">{{ (question.avgTime / 1000)|number_format(1) }}s</span>
                            </td>
                            <td>
                                {% if question.avgTime > 20000 %}
                                    <span class="badge bg-danger">Très difficile</span>
                                {% elseif question.avgTime > 15000 %}
                                    <span class="badge bg-warning">Difficile</span>
                                {% else %}
                                    <span class="badge bg-info">Normale</span>
                                {% endif %}
                            </td>
                            <td>
                                <a
                                    href="{{ ea_url().setController('App\\Controller\\Admin\\QuestionCrudController').setAction('detail').setEntityId(question.id) }}"
                                    class="btn btn-sm btn-primary"
                                >
                                    <i class="fas fa-edit"></i> Réviser
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Catégories Déséquilibrées -->
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-info">⚖️ Catégories Déséquilibrées</h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead>
                            <tr>
                                <th>Catégorie</th>
                                <th>Taux de Réussite</th>
                                <th>Problème</th>
                                <th>Recommandation</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for category in issues.unbalancedCategories %}
                                <tr>
                                    <td>{{ category.categoryName }}</td>
                                    <td>
                                        {% if category.successRate < 30 %}
                                            <span class="badge bg-danger">{{ category.successRate|number_format(1) }}%</span>
                                        {% else %}
                                            <span class="badge bg-success">{{ category.successRate|number_format(1) }}%</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if category.successRate < 30 %}
                                            <span class="text-danger">Trop difficile</span>
                                        {% else %}
                                            <span class="text-success">Trop facile</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if category.successRate < 30 %}
                                            <small>Simplifier les questions ou ajouter des indices</small>
                                        {% else %}
                                            <small>Augmenter la difficulté ou ajouter des variantes</small>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-secondary">⏰ Analyse des Timeouts</h6>
                </div>
                <div class="card-body">
                    <div class="text-center mb-3">
                        <div class="h4 text-danger">{{ issues.timeoutAnalysis.totalTimeouts }}</div>
                        <div class="text-muted">Questions abandonnées</div>
                    </div>

                    {% if issues.timeoutAnalysis.totalTimeouts > 0 %}
                        <div class="text-center mb-3">
                            <div class="h6">{{ (issues.timeoutAnalysis.avgTimeoutTime / 1000)|number_format(1) }}s</div>
                            <div class="text-muted">Temps moyen avant abandon</div>
                        </div>

                        <div class="alert alert-warning">
                            <small>
                                <i class="fas fa-lightbulb"></i>
                                <strong>Conseil:</strong> Les questions avec beaucoup de timeouts sont probablement trop difficiles ou mal formulées.
                            </small>
                        </div>
                    {% else %}
                        <div class="alert alert-success">
                            <i class="fas fa-check"></i> Aucun problème de timeout détecté.
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Actions Correctives -->
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">🔧 Actions Correctives</h6>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <button type="button" class="btn btn-outline-warning" onclick="exportProblems()">
                            <i class="fas fa-download"></i> Exporter Problèmes
                        </button>
                        <a href="{{ path('admin', {routeName: 'admin_stats_tools_difficult_questions'}) }}" class="btn btn-outline-danger">
                            <i class="fas fa-brain"></i> Questions Difficiles
                        </a>

                        <a
                            href="{{ ea_url().setController('App\\Controller\\Admin\\CategoryCrudController').setAction('index') }}"
                            class="btn btn-outline-info"
                        >
                            <i class="fas fa-folder"></i> Gérer Catégories
                        </a>
                        <button type="button" class="btn btn-outline-success" onclick="runDiagnostic()">
                            <i class="fas fa-stethoscope"></i> Diagnostic Complet
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
      function exportProblems() {
        // Logique d'export des problèmes
        alert('Export des problèmes en cours...');
      }

      function runDiagnostic() {
        // Logique de diagnostic
        alert('Diagnostic système lancé...');
      }

      // DataTables pour les sessions problématiques
      $(document).ready(function() {
        $('#problematicSessionsTable').DataTable({
          "language": {
            "url": "//cdn.datatables.net/plug-ins/1.10.24/i18n/French.json"
          },
          "order": [[ 2, "asc" ]], // Trier par score croissant
          "pageLength": 25
        });
      });
    </script>

    <style>
        .question-preview {
            max-width: 300px;
            line-height: 1.2;
            font-size: 0.85rem;
        }
    </style>
{% endblock %}
