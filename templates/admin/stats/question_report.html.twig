{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}
    <i class="fas fa-file-alt"></i> Rapport Complet des Questions
{% endblock %}

{% block main %}
    <div class="container-fluid">
        <!-- En-tête du rapport -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card shadow">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-1">📊 Rapport d'Analyse Complet</h5>
                                <p class="text-muted mb-0">
                                    <i class="fas fa-calendar"></i> Généré le {{ report.generatedAt|date('d/m/Y à H:i') }}
                                </p>
                            </div>
                            <div>
                                <a href="{{ path('admin', {routeName: 'admin_stats_tools_question_analytics'}) }}" class="btn btn-secondary">
                                    <i class="fas fa-arrow-left"></i> Retour
                                </a>
                                <button onclick="window.print()" class="btn btn-primary">
                                    <i class="fas fa-print"></i> Imprimer
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 1. VUE D'ENSEMBLE -->
        <div class="row mb-4">
            <div class="col-12">
                <h4 class="mb-3">
                    <i class="fas fa-chart-line text-primary"></i>
                    Vue d'Ensemble
                </h4>
            </div>

            <div class="col-lg-3 col-md-6 mb-3">
                <div class="card border-start-primary shadow h-100">
                    <div class="card-body">
                        <div class="small fw-bold text-primary text-uppercase mb-1">Total Questions</div>
                        <div class="h5 mb-0 fw-bold">{{ report.overview.totalQuestions }}</div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-3">
                <div class="card border-start-success shadow h-100">
                    <div class="card-body">
                        <div class="small fw-bold text-success text-uppercase mb-1">Questions Utilisées</div>
                        <div class="h5 mb-0 fw-bold">
                            {{ report.overview.answeredQuestions }}
                            <small class="text-muted">({{ report.overview.usageRate }}%)</small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-3">
                <div class="card border-start-info shadow h-100">
                    <div class="card-body">
                        <div class="small fw-bold text-info text-uppercase mb-1">Taux de Réussite Moyen</div>
                        <div class="h5 mb-0 fw-bold">{{ report.overview.averageSuccessRate }}%</div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-3">
                <div class="card border-start-warning shadow h-100">
                    <div class="card-body">
                        <div class="small fw-bold text-warning text-uppercase mb-1">Temps Moyen</div>
                        <div class="h5 mb-0 fw-bold">{{ report.overview.averageResponseTime }}s</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 2. RECOMMANDATIONS -->
        {% if report.recommendations|length > 0 %}
        <div class="row mb-4">
            <div class="col-12">
                <h4 class="mb-3"><i class="fas fa-lightbulb text-warning"></i> Recommandations</h4>
                <div class="card shadow">
                    <div class="card-body">
                        {% for recommendation in report.recommendations %}
                            <div class="alert alert-{{ recommendation.priority == 'high' ? 'danger' : (recommendation.priority == 'medium' ? 'warning' : 'info') }} mb-3">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="mr-3">
                                        {% if recommendation.priority == 'high' %}
                                            <i class="fas fa-exclamation-triangle fa-2x"></i>
                                        {% elseif recommendation.priority == 'medium' %}
                                            <i class="fas fa-exclamation-circle fa-2x"></i>
                                        {% else %}
                                            <i class="fas fa-info-circle fa-2x"></i>
                                        {% endif %}
                                    </div>
                                    <div class="flex-grow-1">
                                        <strong> {{ recommendation.type|upper }}</strong> -
                                        {{ recommendation.message }}
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        <!-- 3. TOP QUESTIONS -->
        <div class="row mb-4">
            <div class="col-12">
                <h4 class="mb-3">
                    <i class="fas fa-star text-warning"></i>
                    Top Questions
                </h4>

                <!-- Card englobante pour les deux sections -->
                <div class="card shadow">
                    <div class="card-body">
                        <!-- Top 10 Questions Faciles -->
                        <div class="mb-4">
                            <h5 class="mb-3"><i class="fas fa-thumbs-up text-success"></i> Top 10 Questions Faciles</h5>
                            <div class="table-responsive">
                            <table class="table table-sm table-hover">
                                <thead>
                                    <tr>
                                        <th>Rang</th>
                                        <th>Question</th>
                                        <th>Taux Réussite</th>
                                        <th>Réponses</th>
                                        <th class="text-center">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for question in report.topQuestions.easiest %}
                                        <tr>
                                            <td><span class="badge bg-success">#{{ loop.index }}</span></td>
                                            <td>
                                                <div class="text-truncate" style="max-width: 300px;">{{ question.entity.content }}</div>
                                            </td>
                                            <td>
                                                <span class="badge bg-success">{{ question.successRate|round(1) }}%</span>
                                            </td>
                                            <td>{{ question.totalAnswers }}</td>
                                            <td class="text-center">
                                                <a
                                                    href="{{ ea_url().setController('App\\Controller\\Admin\\QuestionCrudController').setAction('detail').setEntityId(question.entity.id) }}"
                                                    class="btn btn-sm btn-primary"
                                                    title="Voir la question"
                                                >
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    {% else %}
                                        <tr>
                                            <td colspan="5" class="text-center text-muted">Aucune donnée disponible</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                        </div>

                        <hr class="my-4">

                        <!-- Top 10 Questions Difficiles -->
                        <div>
                            <h5 class="mb-3"><i class="fas fa-thumbs-down text-danger"></i> Top 10 Questions Difficiles</h5>
                            <div class="table-responsive">
                            <table class="table table-sm table-hover">
                                <thead>
                                    <tr>
                                        <th>Rang</th>
                                        <th>Question</th>
                                        <th>Taux Échec</th>
                                        <th>Réponses</th>
                                        <th class="text-center">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for question in report.topQuestions.hardest %}
                                        <tr>
                                            <td><span class="badge bg-danger">#{{ loop.index }}</span></td>
                                            <td>
                                                <div class="text-truncate" style="max-width: 300px;">{{ question.entity.content }}</div>
                                            </td>
                                            <td>
                                                <span class="badge bg-danger">{{ question.failureRate|round(1) }}%</span>
                                            </td>
                                            <td>{{ question.totalAnswers }}</td>
                                            <td class="text-center">
                                                <a
                                                    href="{{ ea_url().setController('App\\Controller\\Admin\\QuestionCrudController').setAction('detail').setEntityId(question.entity.id) }}"
                                                    class="btn btn-sm btn-primary"
                                                    title="Voir la question"
                                                >
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    {% else %}
                                        <tr>
                                            <td colspan="5" class="text-center text-muted">Aucune donnée disponible</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 4. QUESTIONS PROBLÉMATIQUES -->
        <div class="row mb-4">
            <div class="col-12">
                <h4 class="mb-3">
                    <i class="fas fa-exclamation-triangle text-danger"></i>
                    Questions Problématiques
                </h4>

                <!-- Card englobante pour les trois sections -->
                <div class="card shadow">
                    <div class="card-body">
                        <!-- Temps de réponse lent -->
                        <div class="mb-4">
                            <h5 class="mb-3">
                                <span class="fs-4 me-2">🐌</span>
                                Temps de Réponse Lent (>10s)
                            </h5>
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th style="width: 5%;">Rang</th>
                                            <th style="width: 65%;">Question</th>
                                            <th style="width: 15%;">Temps Moyen</th>
                                            <th style="width: 15%;" class="text-center">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% if report.problematicQuestions.slowResponse|length > 0 %}
                                            {% for question in report.problematicQuestions.slowResponse|slice(0, 20) %}
                                                <tr>
                                                    <td><span class="badge bg-warning text-dark">#{{ loop.index }}</span></td>
                                                    <td>
                                                        <div class="lh-base">{{ question.entity.content }}</div>
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-warning text-dark fs-6">
                                                            {{ question.avgTime|round(1) }}s
                                                        </span>
                                                    </td>
                                                    <td class="text-center">
                                                        <a
                                                            href="{{ ea_url().setController('App\\Controller\\Admin\\QuestionCrudController').setAction('detail').setEntityId(question.entity.id) }}"
                                                            class="btn btn-sm btn-primary"
                                                            title="Voir la question"
                                                        >
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        {% else %}
                                            <tr>
                                                <td colspan="4" class="text-center text-muted">✅ Aucune question problématique</td>
                                            </tr>
                                        {% endif %}
                                    </tbody>
                                </table>
                            </div>
                            {% if report.problematicQuestions.slowResponse|length > 20 %}
                                <small class="text-muted">+ {{ report.problematicQuestions.slowResponse|length - 20 }} autre(s) question(s)</small>
                            {% endif %}
                        </div>

                        <hr class="my-4">

                        <!-- Peu de réponses -->
                        <div class="mb-4">
                            <h5 class="mb-3">
                                <span class="fs-4 me-2">📊</span>
                                Peu de Données (<5 réponses)
                            </h5>
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th style="width: 5%;">Rang</th>
                                            <th style="width: 65%;">Question</th>
                                            <th style="width: 15%;">Nb Réponses</th>
                                            <th style="width: 15%;" class="text-center">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% if report.problematicQuestions.fewAnswers|length > 0 %}
                                            {% for question in report.problematicQuestions.fewAnswers|slice(0, 20) %}
                                                <tr>
                                                    <td><span class="badge bg-info text-white">#{{ loop.index }}</span></td>
                                                    <td>
                                                        <div class="lh-base">{{ question.entity.content }}</div>
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-info text-white fs-6">
                                                            {{ question.totalAnswers }} réponse(s)
                                                        </span>
                                                    </td>
                                                    <td class="text-center">
                                                        <a
                                                            href="{{ ea_url().setController('App\\Controller\\Admin\\QuestionCrudController').setAction('detail').setEntityId(question.entity.id) }}"
                                                            class="btn btn-sm btn-primary"
                                                            title="Voir la question"
                                                        >
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        {% else %}
                                            <tr>
                                                <td colspan="4" class="text-center text-muted">✅ Toutes les questions ont assez de données</td>
                                            </tr>
                                        {% endif %}
                                    </tbody>
                                </table>
                            </div>
                            {% if report.problematicQuestions.fewAnswers|length > 20 %}
                                <small class="text-muted">+ {{ report.problematicQuestions.fewAnswers|length - 20 }} autre(s) question(s)</small>
                            {% endif %}
                        </div>

                        <hr class="my-4">

                        <!-- Questions trop faciles -->
                        <div class="mb-4">
                            <h5 class="mb-3">
                                <span class="fs-4 me-2">😴</span>
                                Questions Trop Faciles (&lt;10% échec)
                            </h5>
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th style="width: 5%;">Rang</th>
                                            <th style="width: 65%;">Question</th>
                                            <th style="width: 15%;">Taux Échec</th>
                                            <th style="width: 15%;" class="text-center">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% if report.problematicQuestions.tooEasy|length > 0 %}
                                            {% for question in report.problematicQuestions.tooEasy|slice(0, 20) %}
                                                <tr>
                                                    <td><span class="badge bg-success">#{{ loop.index }}</span></td>
                                                    <td>
                                                        <div class="lh-base">{{ question.entity.content }}</div>
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-success fs-6">
                                                            {{ question.failureRate|round(1) }}%
                                                        </span>
                                                    </td>
                                                    <td class="text-center">
                                                        <a
                                                            href="{{ ea_url().setController('App\\Controller\\Admin\\QuestionCrudController').setAction('detail').setEntityId(question.entity.id) }}"
                                                            class="btn btn-sm btn-primary"
                                                            title="Voir la question"
                                                        >
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        {% else %}
                                            <tr>
                                                <td colspan="4" class="text-center text-muted">✅ Aucune question trop facile</td>
                                            </tr>
                                        {% endif %}
                                    </tbody>
                                </table>
                            </div>
                            {% if report.problematicQuestions.tooEasy|length > 20 %}
                                <small class="text-muted">+ {{ report.problematicQuestions.tooEasy|length - 20 }} autre(s) question(s)</small>
                            {% endif %}
                        </div>

                        <hr class="my-4">

                        <!-- Questions trop difficiles -->
                        <div>
                            <h5 class="mb-3">
                                <span class="fs-4 me-2">💀</span>
                                Questions Trop Difficiles (&gt;90% échec)
                            </h5>
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th style="width: 5%;">Rang</th>
                                            <th style="width: 65%;">Question</th>
                                            <th style="width: 15%;">Taux Échec</th>
                                            <th style="width: 15%;" class="text-center">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% if report.problematicQuestions.tooDifficult|length > 0 %}
                                            {% for question in report.problematicQuestions.tooDifficult|slice(0, 20) %}
                                                <tr>
                                                    <td><span class="badge bg-danger">#{{ loop.index }}</span></td>
                                                    <td>
                                                        <div class="lh-base">{{ question.entity.content }}</div>
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-danger fs-6">
                                                            {{ question.failureRate|round(1) }}%
                                                        </span>
                                                    </td>
                                                    <td class="text-center">
                                                        <a
                                                            href="{{ ea_url().setController('App\\Controller\\Admin\\QuestionCrudController').setAction('detail').setEntityId(question.entity.id) }}"
                                                            class="btn btn-sm btn-primary"
                                                            title="Voir la question"
                                                        >
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        {% else %}
                                            <tr>
                                                <td colspan="4" class="text-center text-muted">✅ Aucune question trop difficile</td>
                                            </tr>
                                        {% endif %}
                                    </tbody>
                                </table>
                            </div>
                            {% if report.problematicQuestions.tooDifficult|length > 20 %}
                                <small class="text-muted">+ {{ report.problematicQuestions.tooDifficult|length - 20 }} autre(s) question(s)</small>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 5. QUESTIONS INUTILISÉES -->
        {% if report.unusedQuestions|length > 0 %}
        <div class="row mb-4">
            <div class="col-12">
                <h4 class="mb-3"><i class="fas fa-archive text-secondary"></i> Questions Jamais Utilisées</h4>
                <div class="card shadow">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table fs-6">
                                <thead>
                                    <tr>
                                        <th>Question</th>
                                        <th>Catégorie</th>
                                        <th>Difficulté</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for question in report.unusedQuestions|slice(0, 20) %}
                                        <tr>
                                            <td>
                                                <div class="lh-sm">{{ question.content }}</div>
                                            </td>
                                            <td>
                                                {% if question.category %}
                                                    <span class="badge bg-primary fs-6">{{ question.category.name }}</span>
                                                {% else %}
                                                    <span class="text-muted">-</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                {% if question.difficulty %}
                                                    <span class="badge badge-difficulty fs-6" style="background-color: {{ question.difficulty.color }};">
                                                        {{ question.difficulty.name }}
                                                    </span>
                                                {% else %}
                                                    <span class="text-muted">-</span>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                        {% if report.unusedQuestions|length > 20 %}
                            <p class="text-muted mb-0">+ {{ report.unusedQuestions|length - 20 }} autre(s) question(s) inutilisée(s)</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        <!-- 6. ANALYSE PAR CATÉGORIE -->
        {% if report.categoryAnalysis|length > 0 %}
        <div class="row mb-4">
            <div class="col-12">
                <h4 class="mb-3"><i class="fas fa-layer-group text-primary"></i> Analyse par Catégorie</h4>
                <div class="card shadow">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover fs-6">
                                <thead>
                                    <tr>
                                        <th>Catégorie</th>
                                        <th>Total Questions</th>
                                        <th>Questions Répondues</th>
                                        <th>Taux Utilisation</th>
                                        <th>Taux Réussite</th>
                                        <th>Temps Moyen</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for category in report.categoryAnalysis %}
                                        <tr>
                                            <td><strong>{{ category.categoryName }}</strong></td>
                                            <td>{{ category.totalQuestions }}</td>
                                            <td>{{ category.answeredQuestions }}</td>
                                            <td>
                                                {% set usageRate = category.totalQuestions > 0 ? (category.answeredQuestions / category.totalQuestions * 100)|round(1) : 0 %}
                                                {% if usageRate > 80 %}
                                                    <span class="badge bg-success fs-6">{{ usageRate }}%</span>
                                                {% elseif usageRate > 50 %}
                                                    <span class="badge bg-warning text-dark fs-6">{{ usageRate }}%</span>
                                                {% else %}
                                                    <span class="badge bg-danger fs-6">{{ usageRate }}%</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                {% if category.avgSuccessRate > 70 %}
                                                    <span class="badge bg-success fs-6">{{ category.avgSuccessRate|round(1) }}%</span>
                                                {% elseif category.avgSuccessRate > 50 %}
                                                    <span class="badge bg-warning text-dark fs-6">{{ category.avgSuccessRate|round(1) }}%</span>
                                                {% else %}
                                                    <span class="badge bg-danger fs-6">{{ category.avgSuccessRate|round(1) }}%</span>
                                                {% endif %}
                                            </td>
                                            <td>{{ (category.avgResponseTime / 1000)|round(1) }}s</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        <!-- 7. ANALYSE PAR DIFFICULTÉ -->
        {% if report.difficultyAnalysis|length > 0 %}
        <div class="row mb-4">
            <div class="col-12">
                <h4 class="mb-3"><i class="fas fa-signal text-info"></i> Analyse par Difficulté</h4>
                <div class="card shadow">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover fs-6">
                                <thead>
                                    <tr>
                                        <th>Difficulté</th>
                                        <th>Total Réponses</th>
                                        <th>Taux Réussite</th>
                                        <th>Temps Moyen</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for difficulty in report.difficultyAnalysis %}
                                        <tr>
                                            <td>
                                                <span class="badge badge-difficulty" style="background-color: {{ difficulty.color }};">
                                                    {{ difficulty.name }}
                                                </span>
                                            </td>
                                            <td>{{ difficulty.totalAnswers }}</td>
                                            <td>
                                                {% if difficulty.successRate > 70 %}
                                                    <span class="badge bg-success fs-6">{{ difficulty.successRate|round(1) }}%</span>
                                                {% elseif difficulty.successRate > 50 %}
                                                    <span class="badge bg-warning text-dark fs-6">{{ difficulty.successRate|round(1) }}%</span>
                                                {% else %}
                                                    <span class="badge bg-danger fs-6">{{ difficulty.successRate|round(1) }}%</span>
                                                {% endif %}
                                            </td>
                                            <td>{{ (difficulty.avgTime / 1000)|round(1) }}s</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

    </div>

    <style>
        /* Borders colorées pour les cards de vue d'ensemble - style spécifique */
        .border-start-primary {
            border-left: 0.25rem solid var(--bs-primary) !important;
        }

        .border-start-success {
            border-left: 0.25rem solid var(--bs-success) !important;
        }

        .border-start-info {
            border-left: 0.25rem solid var(--bs-info) !important;
        }

        .border-start-warning {
            border-left: 0.25rem solid var(--bs-warning) !important;
        }

        /* Badge difficulté avec couleur dynamique */
        .badge-difficulty {
            color: #000 !important;
        }

        /* Impression */
        @media print {
            .btn {
                display: none !important;
            }
        }
    </style>
{% endblock %}
