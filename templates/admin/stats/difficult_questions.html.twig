{% extends '@EasyAdmin/page/content.html.twig' %}

{% block title %}Questions Difficiles{% endblock %}
{% block page_title %}🧠 Questions les Plus Difficiles{% endblock %}

{% block page_content %}
    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i>
        Cette page présente les questions ayant le plus faible taux de réussite pour identifier les points d'amélioration potentiels.
    </div>

    <div class="row mb-4">
        {% for category, failure in categoryFailures|slice(0, 4) %}
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h5 class="card-title">{{ category }}</h5>
                        <h3 class="text-danger">{{ failure.rate }}%</h3>
                        <p class="card-text">d'échec</p>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    <div class="card">
        <div class="card-header">
            <h5><i class="fas fa-list"></i> Questions les Plus Difficiles</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                    <tr>
                        <th>Rang</th>
                        <th>Question</th>
                        <th>Catégorie</th>
                        <th>Taux d'Échec</th>
                        <th>Total Réponses</th>
                        <th>Temps Moyen</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for question in hardestQuestions %}
                        <tr>
                            <td>{{ loop.index }}</td>
                            <td>
                                <div class="question-text">
                                    {{ question.text|length > 80 ? question.text|slice(0, 80) ~ '...' : question.text }}
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-secondary">{{ question.category.name }}</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="progress flex-fill me-2" style="height: 20px;">
                                        <div class="progress-bar bg-danger"
                                             style="width: {{ question.failureRate }}%">
                                            {{ question.failureRate }}%
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td>{{ question.totalAnswers }}</td>
                            <td>{{ (question.avgResponseTime / 1000)|number_format(1) }}s</td>
                            <td>
                                <a href="{{ path('admin', {
                                    crudController: 'App\\Controller\\Admin\\QuestionCrudController',
                                    crudAction: 'detail',
                                    entityId: question.id,
                                }) }}" class="btn btn-sm btn-primary">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <style>
        .question-text {
            max-width: 300px;
            line-height: 1.2;
            font-size: 0.9rem;
        }

        .bg-gold {
            background-color: #ffd700 !important;
        }

        .bg-silver {
            background-color: #c0c0c0 !important;
        }

        .bg-bronze {
            background-color: #cd7f32 !important;
        }
    </style>
{% endblock %}
