{% extends '@EasyAdmin/page/content.html.twig' %}

{% block title %}Tableau de Bord Quiz{% endblock %}

{% block page_title %}🎯 Tableau de Bord Quiz{% endblock %}

{% block page_content %}
    <div class="dashboard-container">
        <!-- Métriques Principales -->
        <div class="row mb-4">
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-primary shadow h-100 py-2">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                    Sessions Totales
                                </div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">
                                    {{ stats.sessions.total|number_format }}
                                </div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-gamepad fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-success shadow h-100 py-2">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                    Taux de Réussite Global
                                </div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">
                                    {{ stats.answers.successRate }}%
                                </div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-check-circle fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-info shadow h-100 py-2">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                    Score Moyen
                                </div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">
                                    {{ stats.scores.average|number_format(1) }}
                                </div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-trophy fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-warning shadow h-100 py-2">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                    Temps de Réponse Moyen
                                </div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">
                                    {{ (stats.answers.avgResponseTime / 1000)|number_format(1) }}s
                                </div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-clock fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Graphiques et Analyses -->
        <div class="row mb-4">
            <!-- Graphique des Sessions par Mode de Jeu -->
            <div class="col-lg-6 mb-4">
                <div class="card shadow">
                    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                        <h6 class="m-0 font-weight-bold text-primary">Sessions par Mode de Jeu</h6>
                    </div>
                    <div class="card-body">
                        <canvas id="gameModeChart" width="100" height="50"></canvas>
                    </div>
                </div>
            </div>

            <!-- Graphique des Performances par Catégorie -->
            <div class="col-lg-6 mb-4">
                <div class="card shadow">
                    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                        <h6 class="m-0 font-weight-bold text-primary">Performance par Catégorie</h6>
                    </div>
                    <div class="card-body">
                        <canvas id="categoryChart" width="100" height="50"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tableau de Bord des Sessions -->
        <div class="row mb-4">
            <!-- Sessions Récentes -->
            <div class="col-lg-6 mb-4">
                <div class="card shadow">
                    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                        <h6 class="m-0 font-weight-bold text-primary">Top 10 - Meilleurs Scores</h6>
                        <a href="{{ path('admin', {crudController: 'App\\Controller\\Admin\\QuizSessionCrudController', crudAction: 'index', 'sort[score]': 'DESC'}) }}" class="btn btn-primary btn-sm">
                            Voir tout
                        </a>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-borderless" id="topSessionsTable">
                                <thead>
                                <tr>
                                    <th>Rang</th>
                                    <th>Joueur</th>
                                    <th>Score</th>
                                    <th>Mode</th>
                                    <th>Date</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for session in stats.scores.topSessions|slice(0, 10) %}
                                    <tr>
                                        <td>{{ loop.index }}</td>
                                        <td>
                                            <strong>{{ session.pseudo }}</strong>
                                            {% if session.user %}
                                                <small class="text-muted">({{ session.user.email }})</small>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <span class="badge badge-success">{{ session.score }}</span>
                                        </td>
                                        <td>
                                            {% set modeLabels = {'20Q': '20Q', TIME_ATTACK: 'Temps', SPEED_RUN: 'Speed', SUDDEN_DEATH: 'Mort'} %}
                                            <span class="badge badge-info">{{ modeLabels[session.gameMode.value] ?? session.gameMode.value }}</span>
                                        </td>
                                        <td>
                                            <small>{{ session.startedAt|date('d/m/Y H:i') }}</small>
                                        </td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Questions les Plus Difficiles -->
            <div class="col-lg-6 mb-4">
                <div class="card shadow">
                    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                        <h6 class="m-0 font-weight-bold text-danger">Questions les Plus Difficiles</h6>
                        <a href="{{ path('admin_stats_tools_difficult_questions') }}" class="btn btn-danger btn-sm">
                            Analyse complète
                        </a>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-borderless">
                                <thead>
                                <tr>
                                    <th>Question</th>
                                    <th>Catégorie</th>
                                    <th>Taux d'échec</th>
                                    <th>Réponses</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for question in stats.hardestQuestions|slice(0, 5) %}
                                    <tr>
                                        <td>
                                            <div class="question-preview">
                                                {{ question.entity.content|length > 50 ? question.entity.content|slice(0, 50) ~ '...' : question.entity.content }}
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge badge-secondary">{{ question.entity.category.name }}</span>
                                        </td>
                                        <td>
                                            <div class="progress" style="height: 20px;">
                                                <div class="progress-bar bg-danger" role="progressbar"
                                                     style="width: {{ question.failureRate }}%"
                                                     aria-valuenow="{{ question.failureRate }}"
                                                     aria-valuemin="0" aria-valuemax="100">
                                                    {{ question.failureRate }}%
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <small>{{ question.totalAnswers }}</small>
                                        </td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tendances et Évolution -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card shadow">
                    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                        <h6 class="m-0 font-weight-bold text-primary">Évolution des Performances (30 derniers jours)</h6>
                    </div>
                    <div class="card-body">
                        <canvas id="trendsChart" width="100" height="30"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Actions Rapides -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card shadow">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">Actions Rapides</h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-3 mb-2">
                                <a href="{{ path('admin', {crudController: 'App\\Controller\\Admin\\QuizSessionCrudController', crudAction: 'index', 'filters[status][value]': 'IN_PROGRESS'}) }}"
                                   class="btn btn-warning btn-block">
                                    <i class="fas fa-play-circle"></i> Sessions en cours ({{ stats.sessions.inProgress }})
                                </a>
                            </div>
                            <div class="col-md-3 mb-2">
                                <a href="{{ path('admin', {crudController: 'App\\Controller\\Admin\\QuizSessionCrudController', crudAction: 'index', 'filters[status][value]': 'FAILED'}) }}"
                                   class="btn btn-danger btn-block">
                                    <i class="fas fa-exclamation-triangle"></i> Sessions échouées
                                </a>
                            </div>
                            <div class="col-md-3 mb-2">
                                <a href="{{ path('admin_stats_tools_export') }}" class="btn btn-info btn-block">
                                    <i class="fas fa-download"></i> Outils d'export
                                </a>
                            </div>
                            <div class="col-md-3 mb-2">
                                <a href="{{ path('admin_stats_tools_system_health') }}" class="btn btn-success btn-block">
                                    <i class="fas fa-heartbeat"></i> État système
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- JavaScript pour les graphiques -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        // Graphique des modes de jeu
        const gameModeCtx = document.getElementById('gameModeChart').getContext('2d');
        new Chart(gameModeCtx, {
          type: 'doughnut',
          data: {
            labels: [
                {% for mode, data in stats.gameModes %}
              '{{ mode }}',
                {% endfor %}
            ],
            datasets: [{
              data: [
                  {% for mode, data in stats.gameModes %}
                  {{ data.count }},
                  {% endfor %}
              ],
              backgroundColor: [
                '#4e73df', '#1cc88a', '#36b9cc', '#f6c23e', '#e74a3b'
              ]
            }]
          },
          options: {
            responsive: true,
            plugins: {
              legend: {
                position: 'bottom'
              }
            }
          }
        });

        // Graphique des catégories
        const categoryCtx = document.getElementById('categoryChart').getContext('2d');
        new Chart(categoryCtx, {
          type: 'bar',
          data: {
            labels: [
                {% for category in stats.categories|slice(0, 8) %}
              '{{ category.name }}',
                {% endfor %}
            ],
            datasets: [{
              label: 'Taux de réussite (%)',
              data: [
                  {% for category in stats.categories|slice(0, 8) %}
                  {{ category.successRate }},
                  {% endfor %}
              ],
              backgroundColor: '#1cc88a'
            }]
          },
          options: {
            responsive: true,
            scales: {
              y: {
                beginAtZero: true,
                max: 100
              }
            }
          }
        });

        // Graphique des tendances
        const trendsCtx = document.getElementById('trendsChart').getContext('2d');
        new Chart(trendsCtx, {
          type: 'line',
          data: {
            labels: [
                {% for day in stats.trends %}
              '{{ day.date|date('d/m') }}',
                {% endfor %}
            ],
            datasets: [{
              label: 'Sessions par jour',
              data: [
                  {% for day in stats.trends %}
                  {{ day.sessions }},
                  {% endfor %}
              ],
              borderColor: '#4e73df',
              backgroundColor: 'rgba(78, 115, 223, 0.1)',
              tension: 0.3
            }, {
              label: 'Score moyen',
              data: [
                  {% for day in stats.trends %}
                  {{ day.avgScore ?? 0 }},
                  {% endfor %}
              ],
              borderColor: '#1cc88a',
              backgroundColor: 'rgba(28, 200, 138, 0.1)',
              tension: 0.3,
              yAxisID: 'y1'
            }]
          },
          options: {
            responsive: true,
            interaction: {
              intersect: false
            },
            scales: {
              y: {
                type: 'linear',
                display: true,
                position: 'left'
              },
              y1: {
                type: 'linear',
                display: true,
                position: 'right',
                grid: {
                  drawOnChartArea: false
                }
              }
            }
          }
        });
      });
    </script>

    <style>
        .border-left-primary {
            border-left: .25rem solid #4e73df !important;
        }
        .border-left-success {
            border-left: .25rem solid #1cc88a !important;
        }
        .border-left-info {
            border-left: .25rem solid #36b9cc !important;
        }
        .border-left-warning {
            border-left: .25rem solid #f6c23e !important;
        }
        .question-preview {
            font-size: 0.85rem;
            line-height: 1.2;
        }
        .dashboard-container {
            padding: 1rem 0;
        }
    </style>
{% endblock %}
