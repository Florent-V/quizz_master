{# templates/admin/fields/questions_count_badge.html.twig #}
{% set count = get_total_questions_count(entity.instance) %}
<span class="badge bg-{% if count > 0 %}primary{% else %}secondary{% endif %} rounded-pill">
    <i class="fas fa-question-circle me-1"></i>
    {{ count }}
    {% if count > 1 %}questions{% else %}question{% endif %}
</span>
