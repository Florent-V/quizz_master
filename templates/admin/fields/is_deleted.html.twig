{# templates/admin/fields/category_status.html.twig #}
{% if field.value %}
    <span class="badge bg-danger">
        <i class="fas fa-trash me-1"></i>
        Supprimé
    </span>
{% else %}
    <span class="badge bg-success">
        <i class="fas fa-check me-1"></i>
        Actif
    </span>
{% endif %}
