{# templates/admin/fields/category_quick_stats.html.twig #}
{% set entity = entity.instance %}
<div class="category-stats">
    <small class="text-muted d-block">
        <i class="fas fa-layer-group"></i> Niveau {{ entity.lvl ?? 0 }}
        {% if entity.children|length > 0 %}
            • <i class="fas fa-sitemap"></i> {{ entity.children|length }} sous-cat.
        {% endif %}
    </small>
</div>
