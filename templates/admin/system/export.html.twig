{% extends '@EasyAdmin/page/content.html.twig' %}

{% block title %}Outils d'Export{% endblock %}
{% block page_title %}📥 Outils d'Export de Données{% endblock %}

{% block page_content %}
    <div data-controller="export-manager">
        <div class="row mb-4">
            <!-- Statistiques d'Export -->
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="card bg-primary text-white shadow h-100">
                    <div class="card-body d-flex flex-column justify-content-center">
                        <div class="text-center">
                            <div class="small fw-bold text-uppercase mb-2" style="opacity: 0.9;">
                                Sessions Totales
                            </div>
                            <div class="h4 mb-0 fw-bold">{{ stats.totalSessions|number_format }}</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-4">
                <div class="card bg-success text-white shadow h-100">
                    <div class="card-body d-flex flex-column justify-content-center">
                        <div class="text-center">
                            <div class="small fw-bold text-uppercase mb-2" style="opacity: 0.9;">
                                Réponses Totales
                            </div>
                            <div class="h4 mb-0 fw-bold">{{ stats.totalAnswers|number_format }}</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-4">
                <div class="card bg-info text-white shadow h-100">
                    <div class="card-body d-flex flex-column justify-content-center">
                        <div class="text-center">
                            <div class="small fw-bold text-uppercase mb-2" style="opacity: 0.9;">
                                Questions Totales
                            </div>
                            <div class="h4 mb-0 fw-bold">{{ stats.totalQuestions|number_format }}</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-4">
                <div class="card shadow h-100" style="background-color: #f39c12; color: white;">
                    <div class="card-body d-flex flex-column justify-content-center">
                        <div class="text-center">
                            <div class="small fw-bold text-uppercase mb-2" style="opacity: 0.9;">
                                Dernier Export
                            </div>
                            <div class="h4 mb-0 fw-bold">{{ stats.lastExports.sessions.date|date('d/m/Y') }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Exports Rapides -->
        <div class="row mb-4">
            <div class="col-lg-8">
                <div class="card shadow">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">⚡ Exports Rapides</h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <div class="card border-left-primary">
                                    <div class="card-body text-center py-3">
                                        <div class="mb-2">
                                            <i class="fas fa-gamepad fa-3x text-primary"></i>
                                        </div>
                                        <h6 class="font-weight-bold">Sessions</h6>
                                        <p class="text-muted small">Toutes les sessions de quiz</p>
                                        <a
                                            href="{{ ea_url().setController('App\\Controller\\Admin\\QuizSessionCrudController').setAction('exportSessions') }}"
                                            class="btn btn-primary btn-sm"
                                        >
                                            <i class="fas fa-download"></i> Exporter CSV
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-4 mb-3">
                                <div class="card border-left-success">
                                    <div class="card-body text-center py-3">
                                        <div class="mb-2">
                                            <i class="fas fa-list fa-3x text-success"></i>
                                        </div>
                                        <h6 class="font-weight-bold">Réponses</h6>
                                        <p class="text-muted small">Toutes les réponses détaillées</p>
                                        <a
                                            href="{{ ea_url().setController('App\\Controller\\Admin\\QuizSessionAnswerCrudController').setAction('exportAnswers') }}"
                                            class="btn btn-success btn-sm"
                                        >
                                            <i class="fas fa-download"></i> Exporter CSV
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-4 mb-3">
                                <div class="card border-left-info">
                                    <div class="card-body text-center py-3">
                                        <div class="mb-2">
                                            <i class="fas fa-folder fa-3x text-info"></i>
                                        </div>
                                        <h6 class="font-weight-bold">Catégories</h6>
                                        <p class="text-muted small">Structure des catégories</p>
                                        <a
                                            href="{{ ea_url().setController('App\\Controller\\Admin\\CategoryCrudController').setAction('exportCategories') }}"
                                            class="btn btn-success btn-sm"
                                        >
                                            <i class="fas fa-download"></i> Exporter CSV
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-info">📊 Exports Statistiques</h6>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <button type="button" class="btn btn-outline-primary"
                                    data-action="click->export-manager#exportStats">
                                <i class="fas fa-chart-bar"></i> Statistiques Globales
                            </button>
                            <button type="button" class="btn btn-outline-success"
                                    data-action="click->export-manager#exportPerformance">
                                <i class="fas fa-tachometer-alt"></i> Analyse Performance
                            </button>
                            <button type="button" class="btn btn-outline-warning"
                                    data-action="click->export-manager#exportProblems">
                                <i class="fas fa-exclamation-triangle"></i> Rapport Problèmes
                            </button>
                            <button type="button" class="btn btn-outline-info"
                                    data-action="click->export-manager#exportTrends">
                                <i class="fas fa-chart-line"></i> Tendances Temporelles
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="alert alert-warning" role="alert">
            ⚠️ La section d'export personnalisé est en cours de développement et ne fonctionne pas actuellement.
        </div>

        <!-- Export Personnalisé -->
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">🎛️ Export Personnalisé</h6>
            </div>
            <div class="card-body">
                <form data-export-manager-target="customForm">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group mb-3">
                                <label class="form-label">Type de Données</label>
                                <select class="form-control" name="dataType">
                                    <option value="sessions">Sessions</option>
                                    <option value="answers">Réponses</option>
                                    <option value="questions">Questions</option>
                                    <option value="users">Utilisateurs</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group mb-3">
                                <label class="form-label">Période</label>
                                <select class="form-control" name="period" data-export-manager-target="periodSelect">
                                    <option value="all">Toutes les données</option>
                                    <option value="today">Aujourd'hui</option>
                                    <option value="week">Cette semaine</option>
                                    <option value="month">Ce mois</option>
                                    <option value="year">Cette année</option>
                                    <option value="custom">Personnalisé</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group mb-3">
                                <label class="form-label">Format</label>
                                <select class="form-control" name="format">
                                    <option value="csv">CSV</option>
                                    <option value="excel">Excel</option>
                                    <option value="json">JSON</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group mb-3">
                                <label class="form-label">&nbsp;</label>
                                <button type="submit" class="btn btn-primary form-control">
                                    <i class="fas fa-download"></i> Exporter
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Filtres avancés -->
                    <div class="row mt-3" style="display: none;" data-export-manager-target="advancedFilters">
                        <div class="col-md-4">
                            <div class="form-group mb-3">
                                <label class="form-label">Date de Début</label>
                                <input type="date" class="form-control" name="startDate">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group mb-3">
                                <label class="form-label">Date de Fin</label>
                                <input type="date" class="form-control" name="endDate">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group mb-3">
                                <label class="form-label">Catégorie</label>
                                <select class="form-control" name="category">
                                    <option value="">Toutes les catégories</option>
                                    <option value="1">Mathématiques</option>
                                    <option value="2">Sciences</option>
                                    <option value="3">Histoire</option>
                                    <option value="4">Géographie</option>
                                    <option value="5">Littérature</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Options avancées -->
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="includeDeleted"
                                       id="includeDeleted">
                                <label class="form-check-label" for="includeDeleted">
                                    Inclure les données supprimées
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="anonymize" id="anonymize" checked>
                                <label class="form-check-label" for="anonymize">
                                    Anonymiser les données personnelles
                                </label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Exports Programmés -->
        <div class="row mb-4">
            <div class="col-lg-6">
                <div class="card shadow">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">⏰ Exports Programmés</h6>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                <tr>
                                    <th>Type</th>
                                    <th>Fréquence</th>
                                    <th>Prochain Export</th>
                                    <th>Statut</th>
                                    <th>Actions</th>
                                </tr>
                                </thead>
                                <tbody>
                                <tr>
                                    <td><span class="badge bg-primary">Sessions</span></td>
                                    <td>Hebdomadaire</td>
                                    <td>{{ 'next monday'|date('d/m/Y') }}</td>
                                    <td><span class="badge bg-success">Actif</span></td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-secondary"
                                                data-action="click->export-manager#toggleSchedule"
                                                data-schedule-type="sessions">
                                            <i class="fas fa-pause"></i>
                                        </button>
                                    </td>
                                </tr>
                                <tr>
                                    <td><span class="badge bg-info">Statistiques</span></td>
                                    <td>Mensuelle</td>
                                    <td>{{ 'first day of next month'|date('d/m/Y') }}</td>
                                    <td><span class="badge bg-secondary">Inactif</span></td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-success"
                                                data-action="click->export-manager#toggleSchedule"
                                                data-schedule-type="stats">
                                            <i class="fas fa-play"></i>
                                        </button>
                                    </td>
                                </tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="text-center mt-3">
                            <button class="btn btn-outline-primary"
                                    data-action="click->export-manager#configureSchedule">
                                <i class="fas fa-cog"></i> Configurer Programmations
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card shadow">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">📈 Graphique d'Export</h6>
                    </div>
                    <div class="card-body">
                        <canvas data-export-manager-target="exportChart" width="100" height="50"></canvas>
                        <div class="row text-center mt-3">
                            <div class="col-4">
                                <div class="text-xs text-gray-500 text-uppercase">Cette Semaine</div>
                                <div class="h6 font-weight-bold">12</div>
                                <div class="text-xs text-success">+15%</div>
                            </div>
                            <div class="col-4">
                                <div class="text-xs text-gray-500 text-uppercase">Ce Mois</div>
                                <div class="h6 font-weight-bold">45</div>
                                <div class="text-xs text-info">+8%</div>
                            </div>
                            <div class="col-4">
                                <div class="text-xs text-gray-500 text-uppercase">Total</div>
                                <div class="h6 font-weight-bold">324</div>
                                <div class="text-xs text-primary">Exports</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Historique des Exports -->
        <div class="card shadow">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-secondary">📂 Historique des Exports</h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered" id="exportHistoryTable">
                        <thead>
                        <tr>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Nombre d'Enregistrements</th>
                            <th>Format</th>
                            <th>Taille</th>
                            <th>Statut</th>
                            <th>Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        <tr>
                            <td>{{ stats.lastExports.sessions.date|date('d/m/Y H:i') }}</td>
                            <td><span class="badge bg-primary">Sessions</span></td>
                            <td>{{ stats.lastExports.sessions.count|number_format }}</td>
                            <td><span class="badge bg-secondary">CSV</span></td>
                            <td>2.4 MB</td>
                            <td><span class="badge bg-success">Terminé</span></td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary"
                                        data-action="click->export-manager#downloadExport"
                                        data-export-id="sessions_latest">
                                    <i class="fas fa-download"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger"
                                        data-action="click->export-manager#deleteExport"
                                        data-export-id="sessions_latest">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                        <tr>
                            <td>{{ stats.lastExports.answers.date|date('d/m/Y H:i') }}</td>
                            <td><span class="badge bg-success">Réponses</span></td>
                            <td>{{ stats.lastExports.answers.count|number_format }}</td>
                            <td><span class="badge bg-secondary">CSV</span></td>
                            <td>8.7 MB</td>
                            <td><span class="badge bg-success">Terminé</span></td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary"
                                        data-action="click->export-manager#downloadExport"
                                        data-export-id="answers_latest">
                                    <i class="fas fa-download"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger"
                                        data-action="click->export-manager#deleteExport"
                                        data-export-id="answers_latest">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                        <tr>
                            <td>{{ stats.lastExports.questions.date|date('d/m/Y H:i') }}</td>
                            <td><span class="badge bg-info">Questions</span></td>
                            <td>{{ stats.lastExports.questions.count|number_format }}</td>
                            <td><span class="badge bg-secondary">CSV</span></td>
                            <td>1.2 MB</td>
                            <td><span class="badge bg-success">Terminé</span></td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary"
                                        data-action="click->export-manager#downloadExport"
                                        data-export-id="questions_latest">
                                    <i class="fas fa-download"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger"
                                        data-action="click->export-manager#deleteExport"
                                        data-export-id="questions_latest">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                        <tr>
                            <td>{{ 'yesterday'|date('d/m/Y H:i') }}</td>
                            <td><span class="badge bg-warning">Statistiques</span></td>
                            <td>-</td>
                            <td><span class="badge bg-secondary">JSON</span></td>
                            <td>456 KB</td>
                            <td><span class="badge bg-warning">En cours</span></td>
                            <td>
                                <button class="btn btn-sm btn-outline-secondary" disabled>
                                    <i class="fas fa-spinner fa-spin"></i>
                                </button>
                            </td>
                        </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <style>
        .border-left-primary {
            border-left: .25rem solid #4e73df !important;
        }

        .border-left-success {
            border-left: .25rem solid #1cc88a !important;
        }

        .border-left-info {
            border-left: .25rem solid #36b9cc !important;
        }

        .modal {
            background-color: rgba(0, 0, 0, 0.5);
        }

        .progress-bar-animated {
            animation: progress-bar-stripes 1s linear infinite;
        }

        @keyframes progress-bar-stripes {
            0% {
                background-position: 1rem 0;
            }
            100% {
                background-position: 0 0;
            }
        }

        .table th {
            border-top: none;
        }

        .btn-sm .fas {
            font-size: 0.8em;
        }

        #exportHistoryTable tbody tr:hover {
            background-color: #f8f9fc;
        }
    </style>
{% endblock %}
