{% extends '@EasyAdmin/page/content.html.twig' %}

{% block title %}Outils d'Export{% endblock %}
{% block page_title %}📥 Outils d'Export de Données{% endblock %}

{% block page_content %}
    <div class="row mb-4">
        <!-- Statistiques d'Export -->
        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card bg-primary text-white shadow">
                <div class="card-body">
                    <div class="text-center">
                        <div class="text-xs font-weight-bold text-white-50 text-uppercase mb-1">
                            Sessions Totales
                        </div>
                        <div class="h4 mb-0 font-weight-bold">{{ stats.totalSessions|number_format }}</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card bg-success text-white shadow">
                <div class="card-body">
                    <div class="text-center">
                        <div class="text-xs font-weight-bold text-white-50 text-uppercase mb-1">
                            Réponses Totales
                        </div>
                        <div class="h4 mb-0 font-weight-bold">{{ stats.totalAnswers|number_format }}</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card bg-info text-white shadow">
                <div class="card-body">
                    <div class="text-center">
                        <div class="text-xs font-weight-bold text-white-50 text-uppercase mb-1">
                            Questions Totales
                        </div>
                        <div class="h4 mb-0 font-weight-bold">{{ stats.totalQuestions|number_format }}</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card bg-warning text-white shadow">
                <div class="card-body">
                    <div class="text-center">
                        <div class="text-xs font-weight-bold text-white-50 text-uppercase mb-1">
                            Dernier Export
                        </div>
                        <div class="h6 mb-0 font-weight-bold">{{ stats.lastExports.sessions.date|date('d/m/Y') }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Exports Rapides -->
    <div class="row mb-4">
        <div class="col-lg-8">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">⚡ Exports Rapides</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <div class="card border-left-primary">
                                <div class="card-body text-center py-3">
                                    <div class="mb-2">
                                        <i class="fas fa-gamepad fa-3x text-primary"></i>
                                    </div>
                                    <h6 class="font-weight-bold">Sessions</h6>
                                    <p class="text-muted small">Toutes les sessions de quiz</p>

                                    <a
                                        href="{{ ea_url().setController('App\Controller\Admin\QuizSessionCrudController').setAction('export') }}"
                                        class="btn btn-primary btn-sm"
                                    >
                                        <i class="fas fa-download"></i> Exporter CSV
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4 mb-3">
                            <div class="card border-left-success">
                                <div class="card-body text-center py-3">
                                    <div class="mb-2">
                                        <i class="fas fa-list fa-3x text-success"></i>
                                    </div>
                                    <h6 class="font-weight-bold">Réponses</h6>
                                    <p class="text-muted small">Toutes les réponses détaillées</p>
                                    <a href="{{ path('admin', {
                                        crudController: 'App\\Controller\\Admin\\QuizSessionAnswerCrudController',
                                        crudAction: 'exportAnswers',
                                    }) }}" class="btn btn-success btn-sm">
                                        <i class="fas fa-download"></i> Exporter CSV
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4 mb-3">
                            <div class="card border-left-info">
                                <div class="card-body text-center py-3">
                                    <div class="mb-2">
                                        <i class="fas fa-folder fa-3x text-info"></i>
                                    </div>
                                    <h6 class="font-weight-bold">Catégories</h6>
                                    <p class="text-muted small">Structure des catégories</p>
                                    <a href="{{ path('admin', {
                                        crudController: 'App\\Controller\\Admin\\CategoryCrudController',
                                        crudAction: 'exportCategories',
                                    }) }}" class="btn btn-info btn-sm">
                                        <i class="fas fa-download"></i> Exporter CSV
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-info">📊 Exports Statistiques</h6>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <button type="button" class="btn btn-outline-primary" onclick="exportStats()">
                            <i class="fas fa-chart-bar"></i> Statistiques Globales
                        </button>
                        <button type="button" class="btn btn-outline-success" onclick="exportPerformance()">
                            <i class="fas fa-tachometer-alt"></i> Analyse Performance
                        </button>
                        <button type="button" class="btn btn-outline-warning" onclick="exportProblems()">
                            <i class="fas fa-exclamation-triangle"></i> Rapport Problèmes
                        </button>
                        <button type="button" class="btn btn-outline-info" onclick="exportTrends()">
                            <i class="fas fa-chart-line"></i> Tendances Temporelles
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Export Personnalisé -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">🎛️ Export Personnalisé</h6>
        </div>
        <div class="card-body">
            <form id="customExportForm">
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group mb-3">
                            <label class="form-label">Type de Données</label>
                            <select class="form-control" name="dataType">
                                <option value="sessions">Sessions</option>
                                <option value="answers">Réponses</option>
                                <option value="questions">Questions</option>
                                <option value="users">Utilisateurs</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="form-group mb-3">
                            <label class="form-label">Période</label>
                            <select class="form-control" name="period">
                                <option value="all">Toutes les données</option>
                                <option value="today">Aujourd'hui</option>
                                <option value="week">Cette semaine</option>
                                <option value="month">Ce mois</option>
                                <option value="year">Cette année</option>
                                <option value="custom">Personnalisé</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="form-group mb-3">
                            <label class="form-label">Format</label>
                            <select class="form-control" name="format">
                                <option value="csv">CSV</option>
                                <option value="excel">Excel</option>
                                <option value="json">JSON</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="form-group mb-3">
                            <label class="form-label">&nbsp;</label>
                            <button type="submit" class="btn btn-primary form-control">
                                <i class="fas fa-download"></i> Exporter
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Filtres avancés -->
                <div class="row mt-3" style="display: none;" id="advancedFilters">
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label class="form-label">Date de Début</label>
                            <input type="date" class="form-control" name="startDate">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label class="form-label">Date de Fin</label>
                            <input type="date" class="form-control" name="endDate">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label class="form-label">Catégorie</label>
                            <select class="form-control" name="category">
                                <option value="">Toutes les catégories</option>
                                <option value="1">Mathématiques</option>
                                <option value="2">Sciences</option>
                                <option value="3">Histoire</option>
                                <option value="4">Géographie</option>
                                <option value="5">Littérature</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Options avancées -->
                <div class="row">
                    <div class="col-md-12">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="includeDeleted" id="includeDeleted">
                            <label class="form-check-label" for="includeDeleted">
                                Inclure les données supprimées
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="anonymize" id="anonymize" checked>
                            <label class="form-check-label" for="anonymize">
                                Anonymiser les données personnelles
                            </label>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Exports Programmés -->
    <div class="row mb-4">
        <div class="col-lg-6">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">⏰ Exports Programmés</h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                            <tr>
                                <th>Type</th>
                                <th>Fréquence</th>
                                <th>Prochain Export</th>
                                <th>Statut</th>
                                <th>Actions</th>
                            </tr>
                            </thead>
                            <tbody>
                            <tr>
                                <td><span class="badge bg-primary">Sessions</span></td>
                                <td>Hebdomadaire</td>
                                <td>{{ 'next monday'|date('d/m/Y') }}</td>
                                <td><span class="badge bg-success">Actif</span></td>
                                <td>
                                    <button class="btn btn-sm btn-outline-secondary" onclick="toggleSchedule('sessions')">
                                        <i class="fas fa-pause"></i>
                                    </button>
                                </td>
                            </tr>
                            <tr>
                                <td><span class="badge bg-info">Statistiques</span></td>
                                <td>Mensuelle</td>
                                <td>{{ 'first day of next month'|date('d/m/Y') }}</td>
                                <td><span class="badge bg-secondary">Inactif</span></td>
                                <td>
                                    <button class="btn btn-sm btn-outline-success" onclick="toggleSchedule('stats')">
                                        <i class="fas fa-play"></i>
                                    </button>
                                </td>
                            </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="text-center mt-3">
                        <button class="btn btn-outline-primary" onclick="configureSchedule()">
                            <i class="fas fa-cog"></i> Configurer Programmations
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">📈 Graphique d'Export</h6>
                </div>
                <div class="card-body">
                    <canvas id="exportStatsChart" width="100" height="50"></canvas>
                    <div class="row text-center mt-3">
                        <div class="col-4">
                            <div class="text-xs text-gray-500 text-uppercase">Cette Semaine</div>
                            <div class="h6 font-weight-bold">12</div>
                            <div class="text-xs text-success">+15%</div>
                        </div>
                        <div class="col-4">
                            <div class="text-xs text-gray-500 text-uppercase">Ce Mois</div>
                            <div class="h6 font-weight-bold">45</div>
                            <div class="text-xs text-info">+8%</div>
                        </div>
                        <div class="col-4">
                            <div class="text-xs text-gray-500 text-uppercase">Total</div>
                            <div class="h6 font-weight-bold">324</div>
                            <div class="text-xs text-primary">Exports</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Historique des Exports -->
    <div class="card shadow">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-secondary">📂 Historique des Exports</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="exportHistoryTable">
                    <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Nombre d'Enregistrements</th>
                        <th>Format</th>
                        <th>Taille</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    <tr>
                        <td>{{ stats.lastExports.sessions.date|date('d/m/Y H:i') }}</td>
                        <td><span class="badge bg-primary">Sessions</span></td>
                        <td>{{ stats.lastExports.sessions.count|number_format }}</td>
                        <td><span class="badge bg-secondary">CSV</span></td>
                        <td>2.4 MB</td>
                        <td><span class="badge bg-success">Terminé</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" onclick="downloadExport('sessions_latest')">
                                <i class="fas fa-download"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" onclick="deleteExport('sessions_latest')">
                                <i class="fas fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                    <tr>
                        <td>{{ stats.lastExports.answers.date|date('d/m/Y H:i') }}</td>
                        <td><span class="badge bg-success">Réponses</span></td>
                        <td>{{ stats.lastExports.answers.count|number_format }}</td>
                        <td><span class="badge bg-secondary">CSV</span></td>
                        <td>8.7 MB</td>
                        <td><span class="badge bg-success">Terminé</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" onclick="downloadExport('answers_latest')">
                                <i class="fas fa-download"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" onclick="deleteExport('answers_latest')">
                                <i class="fas fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                    <tr>
                        <td>{{ stats.lastExports.questions.date|date('d/m/Y H:i') }}</td>
                        <td><span class="badge bg-info">Questions</span></td>
                        <td>{{ stats.lastExports.questions.count|number_format }}</td>
                        <td><span class="badge bg-secondary">CSV</span></td>
                        <td>1.2 MB</td>
                        <td><span class="badge bg-success">Terminé</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" onclick="downloadExport('questions_latest')">
                                <i class="fas fa-download"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" onclick="deleteExport('questions_latest')">
                                <i class="fas fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                    <tr>
                        <td>{{ 'yesterday'|date('d/m/Y H:i') }}</td>
                        <td><span class="badge bg-warning">Statistiques</span></td>
                        <td>-</td>
                        <td><span class="badge bg-secondary">JSON</span></td>
                        <td>456 KB</td>
                        <td><span class="badge bg-warning">En cours</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-secondary" disabled>
                                <i class="fas fa-spinner fa-spin"></i>
                            </button>
                        </td>
                    </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <script>
      // Gestion des exports personnalisés
      document.getElementById('customExportForm').addEventListener('submit', function(e) {
        e.preventDefault();

        const formData = new FormData(this);
        const params = new URLSearchParams(formData);

        // Affichage d'une modal de progression
        showExportProgress();

        // Simulation d'export
        setTimeout(() => {
          hideExportProgress();
          alert('Export terminé avec succès!\nType: ' + formData.get('dataType') + '\nPériode: ' + formData.get('period') + '\nFormat: ' + formData.get('format'));

          // Actualiser l'historique
          location.reload();
        }, 3000);
      });

      // Gestion des filtres avancés
      document.querySelector('select[name="period"]').addEventListener('change', function() {
        const advancedFilters = document.getElementById('advancedFilters');
        if (this.value === 'custom') {
          advancedFilters.style.display = 'block';
        } else {
          advancedFilters.style.display = 'none';
        }
      });

      // Fonctions d'export des statistiques
      function exportStats() {
        showExportProgress();
        setTimeout(() => {
          hideExportProgress();
          window.open('/admin/export/statistics/global.json', '_blank');
        }, 2000);
      }

      function exportPerformance() {
        showExportProgress();
        setTimeout(() => {
          hideExportProgress();
          window.open('/admin/export/statistics/performance.xlsx', '_blank');
        }, 2000);
      }

      function exportProblems() {
        showExportProgress();
        setTimeout(() => {
          hideExportProgress();
          window.open('/admin/export/statistics/problems.pdf', '_blank');
        }, 2000);
      }

      function exportTrends() {
        showExportProgress();
        setTimeout(() => {
          hideExportProgress();
          window.open('/admin/export/statistics/trends.csv', '_blank');
        }, 2000);
      }

      // Gestion des exports programmés
      function toggleSchedule(type) {
        const button = event.target.closest('button');
        const row = button.closest('tr');
        const statusBadge = row.querySelector('.badge');

        if (statusBadge.textContent === 'Actif') {
          statusBadge.className = 'badge bg-secondary';
          statusBadge.textContent = 'Inactif';
          button.innerHTML = '<i class="fas fa-play"></i>';
          button.className = 'btn btn-sm btn-outline-success';
        } else {
          statusBadge.className = 'badge bg-success';
          statusBadge.textContent = 'Actif';
          button.innerHTML = '<i class="fas fa-pause"></i>';
          button.className = 'btn btn-sm btn-outline-secondary';
        }

        alert(`Programmation ${type} ${statusBadge.textContent.toLowerCase()}e`);
      }

      function configureSchedule() {
        alert('Interface de configuration des programmations à venir...');
      }

      // Gestion de l'historique
      function downloadExport(exportId) {
        alert(`Téléchargement de l'export ${exportId}...`);
        // Simulation du téléchargement
      }

      function deleteExport(exportId) {
        if (confirm('Êtes-vous sûr de vouloir supprimer cet export ?')) {
          const button = event.target.closest('button');
          const row = button.closest('tr');
          row.style.opacity = '0.5';

          setTimeout(() => {
            row.remove();
            alert('Export supprimé avec succès');
          }, 1000);
        }
      }

      // Modal de progression
      function showExportProgress() {
        const modal = document.createElement('div');
        modal.id = 'exportProgressModal';
        modal.className = 'modal fade show';
        modal.style.display = 'block';
        modal.innerHTML = `
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-body text-center">
                    <div class="spinner-border text-primary mb-3" role="status">
                        <span class="sr-only">Loading...</span>
                    </div>
                    <h5>Export en cours...</h5>
                    <p class="text-muted">Veuillez patienter pendant la génération de votre export.</p>
                    <div class="progress">
                        <div class="progress-bar progress-bar-striped progress-bar-animated" id="progressBar" style="width: 0%"></div>
                    </div>
                </div>
            </div>
        </div>
    `;

        document.body.appendChild(modal);

        // Animation de la barre de progression
        let progress = 0;
        const interval = setInterval(() => {
          progress += Math.random() * 20;
          if (progress > 100) progress = 100;
          document.getElementById('progressBar').style.width = progress + '%';
          if (progress === 100) clearInterval(interval);
        }, 200);
      }

      function hideExportProgress() {
        const modal = document.getElementById('exportProgressModal');
        if (modal) {
          modal.remove();
        }
      }

      // Graphique des exports
      document.addEventListener('DOMContentLoaded', function() {
        const ctx = document.getElementById('exportStatsChart').getContext('2d');
        new Chart(ctx, {
          type: 'line',
          data: {
            labels: ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'],
            datasets: [{
              label: 'Exports par jour',
              data: [2, 1, 4, 3, 5, 2, 1],
              borderColor: '#4e73df',
              backgroundColor: 'rgba(78, 115, 223, 0.1)',
              tension: 0.3
            }]
          },
          options: {
            responsive: true,
            scales: {
              y: {
                beginAtZero: true
              }
            },
            plugins: {
              legend: {
                display: false
              }
            }
          }
        });
      });
    </script>

    <style>
        .border-left-primary { border-left: .25rem solid #4e73df !important; }
        .border-left-success { border-left: .25rem solid #1cc88a !important; }
        .border-left-info { border-left: .25rem solid #36b9cc !important; }

        .modal {
            background-color: rgba(0, 0, 0, 0.5);
        }

        .progress-bar-animated {
            animation: progress-bar-stripes 1s linear infinite;
        }

        @keyframes progress-bar-stripes {
            0% {
                background-position: 1rem 0;
            }
            100% {
                background-position: 0 0;
            }
        }

        .table th {
            border-top: none;
        }

        .btn-sm .fas {
            font-size: 0.8em;
        }

        #exportHistoryTable tbody tr:hover {
            background-color: #f8f9fc;
        }
    </style>
{% endblock %}
