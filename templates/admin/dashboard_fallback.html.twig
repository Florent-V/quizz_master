{% extends '@EasyAdmin/page/content.html.twig' %}

{% block title %}Tableau de Bord{% endblock %}
{% block page_title %}🎯 Tableau de Bord Quiz (Mode Basique){% endblock %}

{% block page_content %}
    <!-- Message d'erreur -->
    {% if error is defined %}
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle"></i>
            <strong>Attention:</strong> Certaines statistiques avancées ne sont pas disponibles.
            <br><small>Détail technique: {{ error }}</small>
        </div>
    {% endif %}

    <!-- Statistiques de base -->
    <div class="row mb-4">
        <div class="col-xl-2-4 col-md-4 col-sm-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                Sessions
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {{ basic_stats.totalSessions|number_format }}
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-gamepad fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-2-4 col-md-4 col-sm-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                Réponses
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {{ basic_stats.totalAnswers|number_format }}
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-list fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-2-4 col-md-4 col-sm-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                Questions
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {{ basic_stats.totalQuestions|number_format }}
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-question-circle fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-2-4 col-md-4 col-sm-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                Catégories
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {{ basic_stats.totalCategories|number_format }}
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-folder fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-2-4 col-md-4 col-sm-6 mb-4">
            <div class="card border-left-secondary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-secondary text-uppercase mb-1">
                                Utilisateurs
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {{ basic_stats.totalUsers|number_format }}
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-users fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Navigation rapide -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">🚀 Navigation Rapide</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3 mb-3">
                            <a href="{{ path('admin', {
                                crudController: 'App\\Controller\\Admin\\QuizSessionCrudController',
                                crudAction: 'index',
                            }) }}" class="btn btn-primary btn-block">
                                <i class="fas fa-gamepad"></i><br>
                                <small>Gérer Sessions</small>
                            </a>
                        </div>
                        <div class="col-md-3 mb-3">
                            <a href="{{ path('admin', {
                                crudController: 'App\\Controller\\Admin\\QuestionCrudController',
                                crudAction: 'index',
                            }) }}" class="btn btn-success btn-block">
                                <i class="fas fa-question-circle"></i><br>
                                <small>Gérer Questions</small>
                            </a>
                        </div>
                        <div class="col-md-3 mb-3">
                            <a href="{{ path('admin', {
                                crudController: 'App\\Controller\\Admin\\CategoryCrudController',
                                crudAction: 'index',
                            }) }}" class="btn btn-info btn-block">
                                <i class="fas fa-folder"></i><br>
                                <small>Gérer Catégories</small>
                            </a>
                        </div>
                        <div class="col-md-3 mb-3">
                            <a href="{{ path('admin', {
                                crudController: 'App\\Controller\\Admin\\UserCrudController',
                                crudAction: 'index',
                            }) }}" class="btn btn-warning btn-block">
                                <i class="fas fa-users"></i><br>
                                <small>Gérer Utilisateurs</small>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Informations système -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-secondary">ℹ️ Informations</h6>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle"></i>
                        <strong>Mode basique activé:</strong> Le tableau de bord fonctionne en mode dégradé.
                        Les statistiques avancées et graphiques ne sont pas disponibles.
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <h6>Actions recommandées:</h6>
                            <ul>
                                <li>Vérifier la configuration de la base de données</li>
                                <li>S'assurer que le service QuizStatisticsService est disponible</li>
                                <li>Consulter les logs d'application pour plus de détails</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <h6>Liens utiles:</h6>
                            <div class="d-grid gap-2">
                                <a href="{{ path('admin_stats_tools_system_health') }}" class="btn btn-outline-success btn-sm">
                                    <i class="fas fa-heartbeat"></i> État du Système
                                </a>
                                <button class="btn btn-outline-primary btn-sm" onclick="location.reload()">
                                    <i class="fas fa-sync"></i> Actualiser la Page
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .border-left-primary { border-left: .25rem solid #4e73df !important; }
        .border-left-success { border-left: .25rem solid #1cc88a !important; }
        .border-left-info { border-left: .25rem solid #36b9cc !important; }
        .border-left-warning { border-left: .25rem solid #f6c23e !important; }
        .border-left-secondary { border-left: .25rem solid #5a5c69 !important; }

        .btn-block {
            display: block;
            width: 100%;
            padding: 1rem;
        }

        .col-xl-2-4 {
            flex: 0 0 20%;
            max-width: 20%;
        }

        @media (max-width: 1200px) {
            .col-xl-2-4 {
                flex: 0 0 33.333333%;
                max-width: 33.333333%;
            }
        }
    </style>
{% endblock %}
