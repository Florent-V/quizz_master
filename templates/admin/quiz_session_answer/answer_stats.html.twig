{% extends '@EasyAdmin/page/content.html.twig' %}

{% block title %}Statistiques de Réponse{% endblock %}
{% block page_title %}📈 Analyse de Réponse #{{ answer.id }}{% endblock %}

{% block page_content %}
    <div class="row"
         {% if stats.questionStats %}
         data-controller="answer-stats"
         data-answer-stats-correct-answers-value="{{ stats.questionStats.correctAnswers }}"
         data-answer-stats-total-answers-value="{{ stats.questionStats.totalAnswers }}"
         {% endif %}>
        <div class="col-lg-8">
            <!-- Détails de la Réponse -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5><i class="fas fa-question-circle"></i> Détails de la Réponse</h5>
                </div>
                <div class="card-body">
                    <h6><strong>Question:</strong></h6>
                    <p class="alert alert-light">{{ answer.question.content }}</p>

                    <div class="row">
                        <div class="col-md-6">
                            <h6><strong>Votre réponse:</strong></h6>
                            {% if answer.proposal %}
                                <p class="badge {% if answer.isCorrect %}bg-success{% else %}bg-danger{% endif %} fs-6 p-2">
                                    {{ answer.proposal.content }}
                                </p>
                            {% else %}
                                <p class="text-muted">Pas de réponse</p>
                            {% endif %}
                        </div>
                        <div class="col-md-6">
                            <h6><strong>Bonne réponse:</strong></h6>
                            {% for proposal in answer.question.proposals %}
                                {% if proposal.isCorrect %}
                                    <p class="badge bg-success fs-6 p-2">{{ proposal.content }}</p>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>

                    <div class="mt-3">
                        <p><strong>Temps de réponse:</strong> {{ answer.time }}s
                            {% if stats.timeAnalysis %}
                                <span class="badge">{{ stats.timeAnalysis.speed }}</span>
                            {% endif %}
                        </p>
                        <p><strong>Score obtenu:</strong> {{ answer.score ?? 0 }} points</p>
                    </div>
                </div>
            </div>

            <!-- Analyse Comparative -->
            {% if stats.comparison %}
                <div class="card">
                    <div class="card-header">
                        <h5><i class="fas fa-users"></i> Comparaison avec les Autres</h5>
                    </div>
                    <div class="card-body">
                        <p>Cette question a été répondue <strong>{{ stats.comparison.totalAnswers }}</strong> fois.</p>
                        <p>Vous êtes dans le <strong>{{ stats.comparison.percentile }}e percentile</strong> pour le temps de réponse.</p>
                        <p><strong>{{ stats.comparison.fasterAnswers }}</strong> personnes ont répondu plus rapidement que vous.</p>
                    </div>
                </div>
            {% endif %}
        </div>

        <div class="col-lg-4">
            <!-- Statistiques de la Question -->
            {% if stats.questionStats %}
                <div class="card mb-4">
                    <div class="card-header">
                        <h5><i class="fas fa-chart-pie"></i> Stats Question</h5>
                    </div>
                    <div class="card-body text-center">
                        <canvas id="questionStatsChart" width="100" height="100"></canvas>
                        <div class="mt-3">
                            <p><strong>Difficulté:</strong>
                                <span class="badge {% if stats.difficulty == 'Facile' %}bg-success{% elseif stats.difficulty == 'Moyen' %}bg-primary{% elseif stats.difficulty == 'Difficile' %}bg-warning text-dark{% else %}bg-danger{% endif %}">
                                    {{ stats.difficulty }}
                                </span>
                            </p>
                            <p><strong>Taux de réussite:</strong> {{ stats.questionStats.successRate }}%</p>
                            <p><strong>Temps moyen:</strong> {{ stats.questionStats.averageTime }}s</p>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
