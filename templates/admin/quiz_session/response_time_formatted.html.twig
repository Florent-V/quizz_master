<!-- templates/admin/quiz_session/response_time_formatted.html.twig -->
{% set answer = ea.entity.instance %}
{% set time = answer.time %}
{% if time %}
    {% if time < 1000 %}
        <span class="badge bg-success">{{ time }}ms</span>
    {% elseif time < 3000 %}
        <span class="badge bg-primary">{{ (time / 1000)|number_format(1) }}s</span>
    {% elseif time < 10000 %}
        <span class="badge bg-warning">{{ (time / 1000)|number_format(1) }}s</span>
    {% else %}
        <span class="badge bg-danger">{{ (time / 1000)|number_format(1) }}s</span>
    {% endif %}
{% else %}
    <span class="text-muted">-</span>
{% endif %}
