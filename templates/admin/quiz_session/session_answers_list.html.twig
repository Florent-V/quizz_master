{# templates/admin/fields/session_answers_list.html.twig #}
{% set quizSessionAnswers = field.value %}

{% if quizSessionAnswers is not empty %}
    <div class="card mb-3" data-controller="session-answers-list">
        <div class="card-header bg-info">
            <h5 class="mb-0 text-dark">Liste des Réponses</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Question</th>
                        <th>Catégorie</th>
                        <th>Difficulté</th>
                        <th>Réponse Donnée</th>
                        <th>Statut</th>
                        <th>Temps (sec)</th>
                        <th>Score</th>
                        <th>Date de Réponse</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for index, answer in quizSessionAnswers|sort((a, b) => a.askedAt <=> b.askedAt) %}
                        <tr>
                            <td>{{ index + 1 }}</td>
                            <td>
                                <strong>{{ answer.question.content|slice(0, 60) }}{{ answer.question.content|length > 60 ? '...' : '' }}</strong>
                                {% if answer.question.explanation %}
                                    <br>
                                    <small class="text-muted" data-bs-toggle="tooltip" title="{{ answer.question.explanation }}">
                                        <i class="fas fa-info-circle"></i> Explication disponible
                                    </small>
                                {% endif %}
                            </td>
                            <td>
                                <span class="badge bg-secondary">
                                    {{ answer.question.category.name }}
                                </span>
                            </td>
                            <td>
                                <span class="badge bg-{% if answer.question.difficulty.level <= 2 %}success{% elseif answer.question.difficulty.level <= 4 %}warning text-dark{% else %}danger{% endif %}">
                                    {{ answer.question.difficulty.name }} (Niveau {{ answer.question.difficulty.level }})
                                </span>
                            </td>
                            <td>
                                {% if answer.proposal %}
                                    {{ answer.proposal.content }}
                                    {% if answer.proposal.isCorrect %}
                                        <i class="fas fa-check-circle text-success ms-1" data-bs-toggle="tooltip" title="Réponse correcte"></i>
                                    {% endif %}
                                {% else %}
                                    <span class="text-muted">Non répondue</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if answer.isCorrect is not null %}
                                    <span class="badge bg-{{ answer.isCorrect ? 'success' : 'danger' }}">
                                        {{ answer.isCorrect ? 'Correcte' : 'Incorrecte' }}
                                    </span>
                                {% else %}
                                    <span class="text-muted">Non évaluée</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if answer.time is not null %}
                                    {{ answer.time }} sec
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if answer.score is not null %}
                                    {{ answer.score }}
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if answer.answeredAt is not null %}
                                    {{ answer.answeredAt|date('d/m/Y H:i:s') }}
                                {% else %}
                                    <span class="text-muted">Non répondue</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% else %}
    <div class="alert alert-info">
        Aucune réponse enregistrée pour cette session.
    </div>
{% endif %}
